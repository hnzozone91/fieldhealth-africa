{
  "name": "fosafinancecalc",
  "version": "2.0.0",
  "description": "FosaFinanceCalc — Gestion Financière des Recettes Propres, Formations Sanitaires Catégories 3-5, Cameroun",
  "author": {
    "name": "Dr. Nzozone Henry Fomukong",
    "email": "hnzozone91.nh@gmail.com"
  },
  "homepage": "https://hnzozone91.substack.com",
  "license": "MIT",
  "main": "main.js",
  "scripts": {
    "start":      "electron .",
    "pack":       "electron-builder --dir",
    "dist":       "electron-builder",
    "dist:win":   "electron-builder --win",
    "dist:mac":   "electron-builder --mac",
    "dist:linux": "electron-builder --linux"
  },
  "build": {
    "appId": "cm.fosafinancecalc.app",
    "productName": "FosaFinanceCalc",
    "copyright": "© 2026 Dr. Nzozone Henry Fomukong",
    "asar": true,
    "directories": {
      "output": "dist",
      "buildResources": "assets"
    },
    "files": [
      "main.js",
      "preload.js",
      "src/**/*",
      "assets/**/*"
    ],
    "win": {
      "target": [
        { "target": "nsis",     "arch": ["x64", "ia32"] },
        { "target": "portable", "arch": ["x64"] }
      ],
      "icon": "assets/icon.ico",
      "publisherName": "Dr. Nzozone Henry Fomukong",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "allowElevation": true,
      "installerIcon": "assets/icon.ico",
      "uninstallerIcon": "assets/icon.ico",
      "installerHeaderIcon": "assets/icon.ico",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "FosaFinanceCalc",
      "artifactName": "FosaFinanceCalc-Setup-${version}.exe",
      "license": "assets/LICENSE.txt",
      "language": "1036"
    },
    "portable": {
      "artifactName": "FosaFinanceCalc-Portable-${version}.exe"
    },
    "mac": {
      "target": [
        { "target": "dmg", "arch": ["x64", "arm64"] }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.business",
      "artifactName": "FosaFinanceCalc-${version}.dmg"
    },
    "linux": {
      "target": [
        { "target": "AppImage", "arch": ["x64"] },
        { "target": "deb",      "arch": ["x64"] }
      ],
      "icon": "assets/icon.png",
      "category": "Office",
      "artifactName": "FosaFinanceCalc-${version}.AppImage"
    }
  },
  "dependencies": {},
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.0.0"
  }
}
