---
import Base from '../layouts/Base.astro';
import AuroraBackground from '../components/AuroraBackground.astro';

const CONTACT_FORM = 'https://formspree.io/f/xbdbayjg';

const roles = [
  'District Medical Officer (DMO)',
  'District Pharmacist',
  'Facility In-Charge / Manager',
  'M&E Officer',
  'NGO / INGO Programme Staff',
  'Global Health Consultant',
  'Researcher / Academic',
  'Student',
  'Journalist / Media',
  'Other',
];
---

<Base
  title="Contact"
  description="Get in touch with FieldHealth Africa — tool support, partnership enquiries, speaking requests, and general questions."
>

  <section class="relative py-24 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <AuroraBackground variant="b" />
    <!-- Dot-grid overlay -->
    <div aria-hidden="true" class="absolute inset-0 z-[1] pointer-events-none"
         style="background-image: radial-gradient(rgba(6,182,212,0.07) 1px, transparent 1px); background-size: 28px 28px; mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%); -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);"></div>
    <div class="relative z-10 mx-auto max-w-3xl">
      <div class="inline-flex items-center gap-2.5 mb-8">
        <div class="w-8 h-px bg-cyan-400/60" aria-hidden="true"></div>
        <span class="font-mono text-cyan-300/70 text-[11px] uppercase tracking-widest">// contact</span>
      </div>
      <h1 class="font-display font-bold text-4xl sm:text-5xl text-white mb-4">Get in touch</h1>
      <p class="text-white/60 text-lg leading-relaxed">
        Tool support, partnership enquiries, consulting requests, or just a question from the field.
      </p>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8 pb-24">
    <div class="mx-auto max-w-2xl">

      <!-- Clay form card -->
      <div class="relative rounded-3xl [backdrop-filter:blur(22px)] border border-cyan-500/20 overflow-hidden p-8"
           style="background: linear-gradient(145deg, rgba(6,182,212,0.10) 0%, rgba(10,13,18,0.93) 55%, rgba(6,182,212,0.04) 100%); box-shadow: 0 22px 56px -8px rgba(0,0,0,0.62), 0 0 48px -10px rgba(6,182,212,0.25), inset 0 1.5px 0 rgba(255,255,255,0.11), inset 0 -2px 8px rgba(0,0,0,0.30);">
        <div aria-hidden="true" class="absolute top-0 left-10 right-10 h-px" style="background: linear-gradient(90deg, transparent, rgba(6,182,212,0.52), transparent);"></div>

        <p class="font-mono text-[9px] text-cyan-400/45 uppercase tracking-widest mb-5">[ SEND_MESSAGE ]</p>

        <form
          id="contact-form"
          action={CONTACT_FORM}
          method="POST"
          novalidate
          class="space-y-5"
        >
          <input type="hidden" name="_subject" value="FieldHealth Africa contact form" />
          <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />

          <!-- Name + Email -->
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="contact-name" class="block text-white/70 text-xs font-medium mb-1.5">
                Name <span class="text-cyan-400" aria-hidden="true">*</span>
              </label>
              <input
                id="contact-name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class="w-full px-4 py-2.5 rounded-xl bg-white/[0.05] border border-white/10 text-white placeholder-white/25 text-sm focus:outline-none focus:border-cyan-500/60 focus:ring-1 focus:ring-cyan-500/40 transition"
                placeholder="Dr. Henry Fomukong"
              />
            </div>
            <div>
              <label for="contact-email" class="block text-white/70 text-xs font-medium mb-1.5">
                Email <span class="text-cyan-400" aria-hidden="true">*</span>
              </label>
              <input
                id="contact-email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="w-full px-4 py-2.5 rounded-xl bg-white/[0.05] border border-white/10 text-white placeholder-white/25 text-sm focus:outline-none focus:border-cyan-500/60 focus:ring-1 focus:ring-cyan-500/40 transition"
                placeholder="you@example.com"
              />
            </div>
          </div>

          <!-- Role -->
          <div>
            <label for="contact-role" class="block text-white/70 text-xs font-medium mb-1.5">
              Role <span class="text-cyan-400" aria-hidden="true">*</span>
            </label>
            <select
              id="contact-role"
              name="role"
              required
              class="w-full px-4 py-2.5 rounded-xl bg-white/[0.05] border border-white/10 text-white/80 text-sm focus:outline-none focus:border-cyan-500/60 focus:ring-1 focus:ring-cyan-500/40 transition appearance-none"
            >
              <option value="" class="bg-[#0a0d12]">Select your role…</option>
              {roles.map((r) => <option value={r} class="bg-[#0a0d12]">{r}</option>)}
            </select>
          </div>

          <!-- Country -->
          <div>
            <label for="contact-country" class="block text-white/70 text-xs font-medium mb-1.5">
              Country <span class="text-cyan-400" aria-hidden="true">*</span>
            </label>
            <input
              id="contact-country"
              name="country"
              type="text"
              required
              autocomplete="country-name"
              class="w-full px-4 py-2.5 rounded-xl bg-white/[0.05] border border-white/10 text-white placeholder-white/25 text-sm focus:outline-none focus:border-cyan-500/60 focus:ring-1 focus:ring-cyan-500/40 transition"
              placeholder="e.g. Cameroon"
            />
          </div>

          <!-- Message -->
          <div>
            <label for="contact-message" class="block text-white/70 text-xs font-medium mb-1.5">
              Message <span class="text-cyan-400" aria-hidden="true">*</span>
            </label>
            <textarea
              id="contact-message"
              name="message"
              required
              rows="5"
              class="w-full px-4 py-2.5 rounded-xl bg-white/[0.05] border border-white/10 text-white placeholder-white/25 text-sm focus:outline-none focus:border-cyan-500/60 focus:ring-1 focus:ring-cyan-500/40 transition resize-none"
              placeholder="What would you like to discuss?"
            ></textarea>
          </div>

          <p id="contact-error" class="text-red-400 text-xs hidden" role="alert"></p>

          <button
            type="submit"
            id="contact-submit"
            class="w-full py-3.5 rounded-full bg-gradient-to-r from-cyan-500 to-teal-500 hover:from-cyan-400 hover:to-teal-400 text-black font-bold text-base transition-all duration-200 hover:shadow-[0_0_24px_rgba(6,182,212,0.4)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-300 focus-visible:outline-offset-2 disabled:opacity-50 disabled:cursor-not-allowed"
          >
            Send message →
          </button>
        </form>

        <!-- Success state -->
        <div id="contact-thanks" class="text-center py-8 hidden">
          <div class="w-14 h-14 rounded-2xl flex items-center justify-center mx-auto mb-4" aria-hidden="true"
               style="background: linear-gradient(135deg, rgba(6,182,212,0.25) 0%, rgba(6,182,212,0.08) 100%); border: 1px solid rgba(6,182,212,0.30); box-shadow: 0 8px 22px -4px rgba(6,182,212,0.25), inset 0 1px 0 rgba(255,255,255,0.10);">
            <svg class="w-7 h-7 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
          </div>
          <h2 class="font-display font-bold text-xl text-white mb-2">Message sent!</h2>
          <p class="text-white/55 text-sm">We'll be in touch within a few days.</p>
        </div>
      </div>

      <!-- Plain-text fallback -->
      <p class="text-center text-white/35 text-sm mt-6">
        Prefer email?{' '}
        <a href="mailto:hello@fieldhealthafrica.org" class="text-cyan-400/80 hover:text-cyan-300 transition-colors underline underline-offset-2">
          hello@fieldhealthafrica.org
        </a>
      </p>
    </div>
  </section>

</Base>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const submit = document.getElementById('contact-submit') as HTMLButtonElement | null;
  const errEl = document.getElementById('contact-error');
  const thanks = document.getElementById('contact-thanks');

  if (form && submit && errEl && thanks) {
    const action = form.action;
    if (!action.startsWith('[')) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        submit.disabled = true;
        submit.textContent = 'Sending…';
        errEl.classList.add('hidden');
        try {
          const res = await fetch(action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } });
          if (res.ok) {
            form.classList.add('hidden');
            thanks.classList.remove('hidden');
          } else throw new Error();
        } catch {
          errEl.textContent = 'Something went wrong. Please email hello@fieldhealthafrica.org directly.';
          errEl.classList.remove('hidden');
          submit.disabled = false;
          submit.textContent = 'Send message →';
        }
      });
    }
  }
</script>
