---
import Base from '../layouts/Base.astro';
---
<Base title="Privacy Policy" description="FieldHealth Africa privacy policy — how we collect, use, and protect your data.">
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-20">
    <h1 class="font-display font-bold text-3xl text-white mb-4">Privacy Policy</h1>
    <p class="text-white/40 text-sm mb-10">Last updated: May 2026</p>

    <div class="rounded-xl border border-dashed border-white/15 p-6 text-white/40 text-sm italic mb-8">
      TODO — Paste your full Privacy Policy text here. Generate at{' '}
      <a href="https://app.termly.io" target="_blank" rel="noopener noreferrer" class="underline hover:text-white/60">termly.io</a>
      {' '}(free plan). Cover: data collected (name, email, country via forms; analytics via GA4), cookies, third-party processors (Formspree, Cloudflare, Paystack, Substack), data retention, GDPR/rights, contact for requests.
    </div>

    <div class="space-y-6 text-white/60 text-sm leading-relaxed">
      <section>
        <h2 class="font-display font-bold text-lg text-white mb-2">Contact for privacy requests</h2>
        <p>Email: <a href="mailto:hello@fieldhealthafrica.org" class="text-cyan-400 underline underline-offset-2">hello@fieldhealthafrica.org</a></p>
      </section>
    </div>
  </div>
</Base>
