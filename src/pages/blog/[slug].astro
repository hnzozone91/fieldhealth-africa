---
import Base from '../../layouts/Base.astro';
import AffiliateDisclosure from '../../components/AffiliateDisclosure.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

function readingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  const mins = Math.max(1, Math.round(words / 200));
  return `${mins} min read`;
}

const { post } = Astro.props;
const { Content } = await render(post);
const rt = readingTime(post.body ?? '');
---

<Base
  title={post.data.title}
  description={post.data.description}
>

  <article class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-16">

    <!-- Back link -->
    <a href="/blog" class="inline-flex items-center gap-1.5 text-white/40 hover:text-white/70 text-sm transition-colors mb-10 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400 rounded font-mono text-[11px] uppercase tracking-wide">
      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"/></svg>
      // all_posts
    </a>

    <!-- Tags -->
    <div class="flex flex-wrap gap-2 mb-5">
      {post.data.tags.map((tag) => (
        <span class="font-mono px-2.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
              style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.10); color: rgba(255,255,255,0.45);">[ {tag} ]</span>
      ))}
    </div>

    <!-- Headline -->
    <h1 class="font-display font-bold text-3xl sm:text-4xl lg:text-5xl text-white leading-tight mb-4">
      {post.data.title}
    </h1>

    <!-- Meta row -->
    <div class="flex flex-wrap items-center gap-x-4 gap-y-1 font-mono text-[10px] text-white/30 uppercase tracking-wide mb-10 pb-10 border-b border-white/[0.08]">
      <span>{post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
      {post.data.updatedDate && (
        <span>· updated {post.data.updatedDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
      )}
      <span>· {rt}</span>
      <span>· Dr. Nzozone Henry Fomukong</span>
    </div>

    <!-- Affiliate disclosure (top) -->
    {post.data.hasAffiliateLinks && (
      <div class="mb-8">
        <AffiliateDisclosure />
      </div>
    )}

    <!-- Post content -->
    <div class="prose prose-invert prose-sm sm:prose-base max-w-none
                prose-headings:font-display prose-headings:font-bold prose-headings:text-white
                prose-p:text-white/70 prose-p:leading-relaxed
                prose-a:text-cyan-400 prose-a:underline prose-a:underline-offset-2 hover:prose-a:text-cyan-300
                prose-strong:text-white
                prose-code:text-cyan-300 prose-code:bg-white/[0.06] prose-code:px-1.5 prose-code:py-0.5 prose-code:rounded prose-code:font-mono
                prose-blockquote:border-l-cyan-500 prose-blockquote:text-white/60
                prose-li:text-white/70
                prose-hr:border-white/10">
      <Content />
    </div>

    <!-- Affiliate disclosure (bottom) -->
    {post.data.hasAffiliateLinks && (
      <div class="mt-12 pt-8 border-t border-white/[0.08]">
        <AffiliateDisclosure />
      </div>
    )}

    <!-- Substack CTA -->
    <div class="mt-16 relative rounded-3xl [backdrop-filter:blur(22px)] border border-cyan-500/20 overflow-hidden p-8"
         style="background: linear-gradient(145deg, rgba(6,182,212,0.09) 0%, rgba(10,13,18,0.92) 55%, rgba(20,184,166,0.04) 100%); box-shadow: 0 18px 44px -8px rgba(0,0,0,0.58), 0 0 40px -10px rgba(6,182,212,0.20), inset 0 1.5px 0 rgba(255,255,255,0.10), inset 0 -2px 8px rgba(0,0,0,0.28);">
      <div aria-hidden="true" class="absolute top-0 left-8 right-8 h-px" style="background: linear-gradient(90deg, transparent, rgba(6,182,212,0.48), transparent);"></div>
      <div class="flex items-start gap-4">
        <div class="w-10 h-10 rounded-xl flex items-center justify-center flex-shrink-0 mt-0.5" aria-hidden="true"
             style="background: linear-gradient(135deg, rgba(6,182,212,0.25) 0%, rgba(6,182,212,0.08) 100%); border: 1px solid rgba(6,182,212,0.28); box-shadow: 0 6px 18px -4px rgba(6,182,212,0.22), inset 0 1px 0 rgba(255,255,255,0.10);">
          <svg class="w-5 h-5 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
          </svg>
        </div>
        <div class="flex-1 min-w-0">
          <p class="font-mono text-[9px] text-cyan-400/45 uppercase tracking-widest mb-1">[ STAY_CONNECTED ]</p>
          <p class="text-white font-semibold mb-1">New tools. Field notes. No noise.</p>
          <p class="text-white/55 text-sm leading-relaxed mb-4">
            Get notified when new tools launch and read dispatches from the district — straight from Mamfe to your inbox.
          </p>
          <div class="flex flex-col sm:flex-row gap-3">
            <a
              href="https://drhenrynzozone.substack.com"
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center justify-center gap-2 px-6 py-2.5 rounded-full bg-gradient-to-r from-cyan-500 to-teal-500 hover:from-cyan-400 hover:to-teal-400 text-black font-bold text-sm transition-all duration-200 hover:shadow-[0_0_24px_rgba(6,182,212,0.35)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-300 focus-visible:outline-offset-2"
            >
              Subscribe on Substack
            </a>
            {post.data.substackUrl && (
              <a
                href={post.data.substackUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center justify-center gap-2 px-6 py-2.5 rounded-full border border-white/20 text-white/70 font-medium text-sm hover:border-white/35 hover:text-white transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-300 focus-visible:outline-offset-2"
              >
                Read full version on Substack →
              </a>
            )}
          </div>
        </div>
      </div>
    </div>

    <!-- Author footer -->
    <div class="mt-10 pt-8 border-t border-white/[0.08] flex flex-col sm:flex-row items-start sm:items-center justify-between gap-4">
      <div class="flex items-center gap-3">
        <div class="w-10 h-10 rounded-full overflow-hidden flex-shrink-0 border border-cyan-500/20"
             style="box-shadow: 0 4px 14px -2px rgba(6,182,212,0.18);">
          <img src="/images/founder.jpeg" alt="Dr. Nzozone Henry Fomukong" width="40" height="40" class="w-full h-full object-cover" onerror="this.style.display='none'" loading="lazy" />
        </div>
        <div>
          <p class="text-white/80 text-sm font-medium">Dr. Nzozone Henry Fomukong</p>
          <p class="font-mono text-[10px] text-white/35 tracking-wide">MD · Field Epidemiologist · DMO, Mamfe</p>
        </div>
      </div>
      <a href="/blog" class="font-mono text-[10px] text-white/35 hover:text-white/60 uppercase tracking-widest transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400 rounded">
        // more_posts →
      </a>
    </div>

  </article>

</Base>
