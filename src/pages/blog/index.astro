---
import Base from '../../layouts/Base.astro';
import AuroraBackground from '../../components/AuroraBackground.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function readingTime(body: string) {
  const words = body.trim().split(/\s+/).length;
  const mins = Math.max(1, Math.round(words / 200));
  return `${mins} min read`;
}
---

<Base
  title="Blog"
  description="Field notes, tool walkthroughs, and dispatches from the district — by Dr. Nzozone Henry Fomukong, DMO, Mamfe."
>

  <section class="relative py-24 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <AuroraBackground variant="b" />
    <div aria-hidden="true" class="absolute inset-0 z-[1] pointer-events-none"
         style="background-image: radial-gradient(rgba(6,182,212,0.07) 1px, transparent 1px); background-size: 28px 28px; mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%); -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);"></div>
    <div class="relative z-10 mx-auto max-w-3xl">
      <div class="inline-flex items-center gap-2.5 mb-8">
        <div class="w-8 h-px bg-cyan-400/60" aria-hidden="true"></div>
        <span class="font-mono text-cyan-300/70 text-[11px] uppercase tracking-widest">// field_notes</span>
      </div>
      <h1 class="font-display font-bold text-4xl sm:text-5xl text-white mb-4">Field notes &amp; dispatches</h1>
      <p class="text-white/60 text-lg leading-relaxed">Tool walkthroughs, methodology notes, and writing from the district.</p>
    </div>
  </section>

  <section class="py-8 px-4 sm:px-6 lg:px-8 pb-24">
    <div class="mx-auto max-w-3xl space-y-4">
      {posts.map((post, i) => (
        <a
          href={`/blog/${post.id}`}
          data-reveal
          data-reveal-delay={i > 0 ? String(Math.min(i * 100, 500)) : undefined}
          class="group relative block rounded-3xl [backdrop-filter:blur(22px)] border border-white/[0.10] overflow-hidden p-6 transition-all duration-300 focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400 focus-visible:outline-offset-2"
          style="background: linear-gradient(145deg, rgba(6,182,212,0.06) 0%, rgba(10,13,18,0.90) 60%, rgba(6,182,212,0.02) 100%); box-shadow: 0 14px 40px -8px rgba(0,0,0,0.55), 0 0 32px -12px rgba(6,182,212,0.12), inset 0 1.5px 0 rgba(255,255,255,0.08), inset 0 -2px 8px rgba(0,0,0,0.28);"
        >
          <div aria-hidden="true" class="absolute top-0 left-8 right-8 h-px opacity-0 group-hover:opacity-100 transition-opacity duration-300" style="background: linear-gradient(90deg, transparent, rgba(6,182,212,0.40), transparent);"></div>
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-2">
                {post.data.tags.map((tag) => (
                  <span class="font-mono px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
                        style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.08); color: rgba(255,255,255,0.40);">{tag}</span>
                ))}
                {post.data.hasAffiliateLinks && (
                  <span class="font-mono px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
                        style="background: rgba(245,158,11,0.10); border: 1px solid rgba(245,158,11,0.20); color: rgba(252,211,77,0.65);">[ affiliate ]</span>
                )}
              </div>
              <h2 class="font-display font-bold text-xl text-white group-hover:text-cyan-100 transition-colors mb-1.5">{post.data.title}</h2>
              <p class="text-white/55 text-sm leading-relaxed">{post.data.description}</p>
            </div>
            <svg class="w-5 h-5 text-white/20 group-hover:text-cyan-400 group-hover:translate-x-0.5 transition-all flex-shrink-0 mt-1" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </div>
          <div class="flex items-center gap-3 mt-4 font-mono text-[10px] text-white/30">
            <span>{post.data.pubDate.toLocaleDateString('en-GB', { day: 'numeric', month: 'long', year: 'numeric' })}</span>
            <span aria-hidden="true">·</span>
            <span>{readingTime(post.body ?? '')}</span>
          </div>
        </a>
      ))}

      {posts.length === 0 && (
        <div class="text-center py-20 text-white/30">
          <p class="font-mono text-[10px] uppercase tracking-widest mb-3">[ NO_POSTS_YET ]</p>
          <p class="text-lg">No posts yet.</p>
          <p class="text-sm mt-2">First post coming soon.</p>
        </div>
      )}
    </div>
  </section>

</Base>
