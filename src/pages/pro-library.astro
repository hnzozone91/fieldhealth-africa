---
import Base from '../layouts/Base.astro';
import AuroraBackground from '../components/AuroraBackground.astro';
import NewsletterBand from '../components/NewsletterBand.astro';
import { products } from '../data/products';

// TODO: replace with real Formspree endpoint for "Notify me" capture
const NOTIFY_FORM = '[FORMSPREE_NOTIFY_ENDPOINT]';

const inDevelopment = [
  { title: 'Malaria Burden Estimator',        desc: 'District-level malaria burden modelling using DHIS2 data, rainfall, and population denominators.' },
  { title: 'CHW Performance Dashboard',       desc: 'Real-time community health worker activity tracking with target-vs-actual and geospatial views.' },
  { title: 'HMIS Data Quality Toolkit',       desc: 'Automated completeness, consistency, and timeliness scoring across DHIS2 organisation units.' },
  { title: 'ANC Cascade Analyser',            desc: 'Full antenatal care cascade from first visit to delivery — drop-off identification and equity stratification.' },
];
---

<Base
  title="Pro Library"
  description="Premium digital health tools for global health professionals. Python apps, AI-powered dashboards, and predictive models built by a practising District Medical Officer."
>

  <!-- Hero -->
  <section class="relative py-24 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <AuroraBackground variant="b" />
    <div class="relative z-10 mx-auto max-w-3xl">
      <div class="inline-flex items-center gap-2.5 mb-8">
        <div class="w-8 h-px bg-teal-400/60" aria-hidden="true"></div>
        <span class="text-teal-300/80 text-xs font-semibold uppercase tracking-widest">Pro Library</span>
      </div>
      <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-white leading-tight mb-6">
        Premium tools for<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-300 to-emerald-300">global health professionals.</span>
      </h1>
      <p class="text-white/65 text-lg leading-relaxed">
        Built by a practising DMO. Backed by seven peer-reviewed publications.
        Designed for the consultants, NGOs, and researchers who need tools that save billable hours — not prototypes.
      </p>
    </div>
  </section>


  <!-- Pricing model -->
  <section class="py-12 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <h2 class="font-display font-bold text-2xl text-white mb-6">Pricing model</h2>
      <div data-reveal class="grid grid-cols-1 sm:grid-cols-3 gap-4">
        {[
          { tier: 'À la carte', range: '$79 – $799', desc: 'Buy a single tool outright. Includes source code, documentation, and 30-day email support. Best for one-time project needs.' },
          { tier: 'Subscription', range: '$29 – $999 / mo', desc: 'Access the full growing Pro Library. Best for consultants who need tools across multiple projects and want new releases included.' },
          { tier: 'Enterprise', range: '$5,000 – $35,000', desc: 'Custom tool development, training, integration support, and multi-seat licensing for teams and institutions.' },
        ].map(({ tier, range, desc }) => (
          <div class="rounded-2xl bg-white/[0.04] border border-white/[0.13] ring-1 ring-teal-500/15 p-6">
            <p class="text-teal-400 text-xs font-semibold uppercase tracking-widest mb-1">{tier}</p>
            <p class="font-display font-bold text-xl text-white mb-3">{range}</p>
            <p class="text-white/55 text-sm leading-relaxed">{desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Live product(s) -->
  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-6">Available now</p>

      {products.filter(p => p.status === 'live').map((product) => (
        <div class="rounded-2xl bg-gradient-to-br from-white/[0.08] to-white/[0.03] [backdrop-filter:blur(18px)] border border-white/[0.13] ring-1 ring-teal-400/30 shadow-[0_0_40px_-6px_rgba(20,184,166,0.22)] overflow-hidden mb-6">
          <div class="p-8">
            <div class="flex flex-col lg:flex-row gap-8">

              <!-- Info -->
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-3">
                  <span class="px-2.5 py-0.5 rounded-full bg-teal-500/15 border border-teal-400/30 text-teal-300 text-[10px] font-bold uppercase tracking-wider">Live</span>
                  <span class="text-white/30 text-xs">À la carte</span>
                </div>
                <h2 class="font-display font-bold text-2xl text-white mb-3">{product.name}</h2>
                <p class="text-white/60 text-sm leading-relaxed mb-5">{product.description}</p>

                <!-- Deliverables -->
                <div class="mb-6">
                  <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-3">What you get</p>
                  <ul class="space-y-2">
                    {product.deliverables.map((item) => (
                      <li class="flex items-start gap-2.5 text-sm text-white/65">
                        <svg class="w-4 h-4 text-teal-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <!-- Buy panel -->
              <div class="lg:w-64 flex-shrink-0">
                <div class="rounded-2xl bg-white/[0.04] border border-teal-500/20 p-6 text-center sticky top-28">
                  <p class="text-white/40 text-xs mb-1">One-time payment</p>
                  <p class="font-display font-bold text-4xl text-white mb-1">${product.price}</p>
                  <p class="text-white/40 text-xs mb-6">{product.currency} · MTN MoMo · Orange Money · Card</p>

                  {product.live && !product.paystackLink.startsWith('[') ? (
                    <a
                      href={product.paystackLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block w-full py-3.5 rounded-full bg-gradient-to-r from-teal-500 to-emerald-500 hover:from-teal-400 hover:to-emerald-400 text-black font-bold text-sm transition-all duration-200 hover:shadow-[0_0_24px_rgba(20,184,166,0.4)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-teal-300 focus-visible:outline-offset-2 mb-3"
                    >
                      Buy now →
                    </a>
                  ) : (
                    <div class="mb-3">
                      <div class="block w-full py-3.5 rounded-full bg-white/10 border border-white/15 text-white/40 font-bold text-sm text-center cursor-not-allowed mb-2">
                        Buy now
                      </div>
                      {/* Visible placeholder note — remove after pasting real link */}
                      <p class="text-amber-400/70 text-[10px] text-center leading-tight">
                        TODO: paste real Paystack link<br/>[PAYSTACK_LINK_DRUG_STOCKOUT]
                      </p>
                    </div>
                  )}

                  <p class="text-white/30 text-[11px] leading-relaxed">
                    Secure payment via Paystack.<br/>
                    Download instructions sent by email after purchase.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Footer note -->
          <div class="border-t border-white/[0.06] px-8 py-4 text-xs text-white/35">
            After purchase → <a href="/checkout-success" class="underline underline-offset-2 hover:text-white/55 transition-colors">see what happens next</a>.
            Questions? <a href="/contact" class="underline underline-offset-2 hover:text-white/55 transition-colors">Contact us.</a>
          </div>
        </div>
      ))}
    </div>
  </section>


  <!-- In development -->
  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="text-white/40 text-xs font-semibold uppercase tracking-widest mb-6">In development</p>
      <div data-reveal class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {inDevelopment.map(({ title, desc }) => (
          <div class="rounded-2xl bg-white/[0.02] border border-white/[0.06] p-5 opacity-60 relative overflow-hidden">
            <div class="absolute inset-0 opacity-[0.025]" style="background-image: repeating-linear-gradient(45deg, white, white 1px, transparent 1px, transparent 8px);" aria-hidden="true"></div>
            <div class="relative">
              <span class="inline-block px-2.5 py-0.5 rounded-full bg-white/10 text-white/40 text-[10px] font-bold uppercase tracking-wider mb-3">In development</span>
              <h3 class="font-display font-bold text-base text-white/70 mb-1.5">{title}</h3>
              <p class="text-white/40 text-xs leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Notify me -->
  <section class="py-12 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <div class="rounded-2xl bg-gradient-to-br from-white/[0.08] to-white/[0.03] [backdrop-filter:blur(18px)] border border-white/[0.13] ring-1 ring-teal-500/15 p-8 text-center">
        <h2 class="font-display font-bold text-xl text-white mb-2">Notify me when more Pro tools launch</h2>
        <p class="text-white/55 text-sm mb-6">Drop your email — we'll reach out before public launch, sometimes with an early-access discount.</p>

        <!-- TODO: replace action with real Formspree endpoint [FORMSPREE_NOTIFY_ENDPOINT] -->
        <form
          action={NOTIFY_FORM}
          method="POST"
          class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto"
          id="notify-form"
        >
          <input type="hidden" name="_subject" value="Pro Library Notify Me" />
          <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
          <label for="notify-email" class="sr-only">Email address</label>
          <input
            id="notify-email"
            name="email"
            type="email"
            required
            placeholder="your@email.com"
            class="flex-1 px-4 py-2.5 rounded-full bg-white/[0.05] border border-white/10 text-white placeholder-white/25 text-sm focus:outline-none focus:border-teal-500/60 focus:ring-1 focus:ring-teal-500/40 transition"
          />
          <button
            type="submit"
            class="px-6 py-2.5 rounded-full bg-gradient-to-r from-teal-500 to-emerald-500 hover:from-teal-400 hover:to-emerald-400 text-black font-bold text-sm transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-teal-300 focus-visible:outline-offset-2 whitespace-nowrap"
          >
            Notify me
          </button>
        </form>
        <p id="notify-thanks" class="text-teal-400 text-sm font-medium hidden">✓ You're on the list!</p>
      </div>
    </div>
  </section>

  <NewsletterBand />

</Base>

<script>
  const form = document.getElementById('notify-form') as HTMLFormElement | null;
  const thanks = document.getElementById('notify-thanks');
  if (form && thanks) {
    const action = form.action;
    if (!action.startsWith('[')) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const res = await fetch(action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } });
        if (res.ok) { form.classList.add('hidden'); thanks.classList.remove('hidden'); }
      });
    }
  }
</script>


