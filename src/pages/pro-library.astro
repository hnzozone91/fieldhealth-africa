---
import Base from '../layouts/Base.astro';
import AuroraBackground from '../components/AuroraBackground.astro';
import NewsletterBand from '../components/NewsletterBand.astro';
import { products } from '../data/products';

const NOTIFY_FORM = 'https://formspree.io/f/xbdbayjg';

const inDevelopment = [
  { title: 'Malaria Burden Estimator',        desc: 'District-level malaria burden modelling using DHIS2 data, rainfall, and population denominators.' },
  { title: 'CHW Performance Dashboard',       desc: 'Real-time community health worker activity tracking with target-vs-actual and geospatial views.' },
  { title: 'HMIS Data Quality Toolkit',       desc: 'Automated completeness, consistency, and timeliness scoring across DHIS2 organisation units.' },
  { title: 'ANC Cascade Analyser',            desc: 'Full antenatal care cascade from first visit to delivery — drop-off identification and equity stratification.' },
];
---

<Base
  title="Pro Library"
  description="Premium digital health tools for global health professionals. Python apps, AI-powered dashboards, and predictive models built by a practising District Medical Officer."
>

  <!-- Hero -->
  <section class="relative py-24 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <AuroraBackground variant="b" />
    <div aria-hidden="true" class="absolute inset-0 z-[1] pointer-events-none"
         style="background-image: radial-gradient(rgba(20,184,166,0.07) 1px, transparent 1px); background-size: 28px 28px; mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%); -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);"></div>
    <div class="relative z-10 mx-auto max-w-3xl">
      <div class="inline-flex items-center gap-2.5 mb-8">
        <div class="w-8 h-px bg-teal-400/60" aria-hidden="true"></div>
        <span class="font-mono text-teal-300/70 text-[11px] uppercase tracking-widest">// pro_library</span>
      </div>
      <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-white leading-tight mb-6">
        Premium tools for<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-teal-300 to-emerald-300">global health professionals.</span>
      </h1>
      <p class="text-white/65 text-lg leading-relaxed">
        Built by a practising DMO. Backed by seven peer-reviewed publications.
        Designed for the consultants, NGOs, and researchers who need tools that save billable hours — not prototypes.
      </p>
    </div>
  </section>


  <!-- FosaFinanceCalc -->
  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="font-mono text-[10px] text-teal-400/45 uppercase tracking-widest mb-6">// available_now</p>
      <div data-reveal
           class="relative rounded-3xl [backdrop-filter:blur(22px)] border border-emerald-500/25 overflow-hidden"
           style="background: linear-gradient(145deg, rgba(16,185,129,0.10) 0%, rgba(10,13,18,0.92) 55%, rgba(16,185,129,0.04) 100%); box-shadow: 0 22px 56px -8px rgba(0,0,0,0.62), 0 0 52px -10px rgba(16,185,129,0.22), inset 0 1.5px 0 rgba(255,255,255,0.11), inset 0 -2px 8px rgba(0,0,0,0.30);">
        <div aria-hidden="true" class="absolute top-0 left-10 right-10 h-px" style="background: linear-gradient(90deg, transparent, rgba(16,185,129,0.55), transparent);"></div>
        <div class="p-8">
          <div class="flex flex-col lg:flex-row gap-8 items-start">
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-3">
                <span class="font-mono px-2.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
                      style="background: rgba(16,185,129,0.15); border: 1px solid rgba(16,185,129,0.32); color: rgba(110,231,183,0.9);">[ LIVE ]</span>
                <span class="font-mono px-2.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
                      style="background: rgba(16,185,129,0.10); border: 1px solid rgba(16,185,129,0.25); color: rgba(110,231,183,0.7);">[ FREE ]</span>
                <span class="font-mono text-white/30 text-[10px]">v2.2 · Windows Desktop App · Offline</span>
              </div>
              <h2 class="font-display font-bold text-2xl text-white mb-3">FosaFinanceCalc v2.2</h2>
              <p class="text-white/60 text-sm leading-relaxed mb-5">
                Standalone Windows desktop application for financial management of Category 3–5 health facilities
                in Cameroon. Automates the 6-step Recettes Propres calculation, decade-by-decade Treasury deposits,
                6-way IGF triangulation audit, and generates print-ready reports — fully offline, no browser required.
                Built and tested in Mamfe District. Compliant with Décret 2016/6447/PM and RGCP.
              </p>
              <ul class="space-y-2 mb-6">
                {[
                  'Full desktop app — no browser, no internet, no installation (portable version)',
                  '10 modules: Dashboard, Registers, Cash Journal, Treasury, Solidarity, Pharmacy, Expenditures, QP, Triangulation, Report',
                  '6-way triangulation audit replicating IGF inspection — runs in seconds',
                  'Decade-aware Treasury and Solidarity calculations (not monthly average)',
                  'CSV / Excel export on every module',
                  'French interface · Bilingual user guide (FR / EN)',
                ].map(item => (
                  <li class="flex items-start gap-2.5 text-sm text-white/65">
                    <svg class="w-4 h-4 text-emerald-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
              <div class="flex flex-col sm:flex-row gap-3">
                <a
                  href="https://github.com/hnzozone91/fosafinancecalc/releases/download/v2.2.0/FosaFinanceCalc-Setup-2.2.0.exe"
                  class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-emerald-500 to-teal-500 hover:from-emerald-400 hover:to-teal-400 text-black font-bold text-sm transition-all duration-200 hover:shadow-[0_0_24px_rgba(16,185,129,0.4)]"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  Download Installer (135 MB) →
                </a>
                <a
                  href="https://github.com/hnzozone91/fosafinancecalc/releases/download/v2.2.0/FosaFinanceCalc-Portable-2.2.0.exe"
                  class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white/10 border border-emerald-500/30 hover:bg-white/15 text-white font-bold text-sm transition-all duration-200"
                >
                  <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                  Portable (72 MB, no install)
                </a>
              </div>
            </div>
          </div>
        </div>
        <div class="border-t px-8 py-4 flex flex-wrap gap-4 font-mono text-[10px] text-white/30" style="border-color: rgba(16,185,129,0.10);">
          <span>[ windows ] Windows 10/11 · x64 &amp; ia32</span>
          <span>[ offline ] Fully offline · No internet required</span>
          <span>[ compliant ] Décret 2016/6447/PM · RGCP</span>
          <span>[ free ] No payment · No login · Direct download</span>
        </div>
      </div>
    </div>
  </section>


  <!-- Live product(s) -->
  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="font-mono text-[10px] text-teal-400/45 uppercase tracking-widest mb-6">// available_now</p>

      {products.filter(p => p.status === 'live').map((product) => (
        <div data-reveal
             class="relative rounded-3xl [backdrop-filter:blur(22px)] border border-teal-500/25 overflow-hidden mb-6"
             style="background: linear-gradient(145deg, rgba(20,184,166,0.10) 0%, rgba(10,13,18,0.92) 55%, rgba(20,184,166,0.04) 100%); box-shadow: 0 22px 56px -8px rgba(0,0,0,0.62), 0 0 52px -10px rgba(20,184,166,0.25), inset 0 1.5px 0 rgba(255,255,255,0.11), inset 0 -2px 8px rgba(0,0,0,0.30);">
          <div aria-hidden="true" class="absolute top-0 left-10 right-10 h-px" style="background: linear-gradient(90deg, transparent, rgba(20,184,166,0.55), transparent);"></div>
          <div class="p-8">
            <div class="flex flex-col lg:flex-row gap-8">

              <!-- Info -->
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-3">
                  <span class="font-mono px-2.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
                        style="background: rgba(20,184,166,0.15); border: 1px solid rgba(20,184,166,0.32); color: rgba(94,234,212,0.9);">[ LIVE ]</span>
                  <span class="font-mono text-white/30 text-[10px]">À la carte</span>
                </div>
                <h2 class="font-display font-bold text-2xl text-white mb-3">{product.name}</h2>
                <p class="text-white/60 text-sm leading-relaxed mb-5">{product.description}</p>

                <!-- Deliverables -->
                <div class="mb-6">
                  <p class="font-mono text-[9px] text-teal-400/45 uppercase tracking-widest mb-3">[ WHAT_YOU_GET ]</p>
                  <ul class="space-y-2">
                    {product.deliverables.map((item) => (
                      <li class="flex items-start gap-2.5 text-sm text-white/65">
                        <svg class="w-4 h-4 text-teal-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                        {item}
                      </li>
                    ))}
                  </ul>
                </div>
              </div>

              <!-- Buy panel -->
              <div class="lg:w-64 flex-shrink-0">
                <div class="rounded-2xl border border-teal-500/20 p-6 text-center sticky top-28"
                     style="background: rgba(20,184,166,0.05); box-shadow: inset 0 1px 0 rgba(255,255,255,0.06);">
                  <p class="font-mono text-[9px] text-teal-400/40 uppercase tracking-widest mb-1">[ ONE_TIME_PAYMENT ]</p>
                  <p class="font-display font-bold text-4xl text-white mb-1">${product.price}</p>
                  <p class="font-mono text-white/35 text-[10px] mb-6">{product.currency} · MTN MoMo · Orange Money · Card</p>

                  {product.live && !product.paystackLink.startsWith('[') ? (
                    <a
                      href={product.paystackLink}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="block w-full py-3.5 rounded-full bg-gradient-to-r from-teal-500 to-emerald-500 hover:from-teal-400 hover:to-emerald-400 text-black font-bold text-sm transition-all duration-200 hover:shadow-[0_0_24px_rgba(20,184,166,0.4)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-teal-300 focus-visible:outline-offset-2 mb-3"
                    >
                      Buy now →
                    </a>
                  ) : (
                    <div class="mb-3">
                      <div class="block w-full py-3.5 rounded-full bg-white/10 border border-white/15 text-white/40 font-bold text-sm text-center cursor-not-allowed mb-2">
                        Buy now
                      </div>
                      <p class="font-mono text-white/30 text-[10px] text-center leading-tight">
                        Coming soon
                      </p>
                    </div>
                  )}

                  <p class="font-mono text-white/25 text-[10px] leading-relaxed tracking-wide">
                    Secure payment via Paystack.<br/>
                    Download link sent by email.
                  </p>
                </div>
              </div>
            </div>
          </div>

          <div class="border-t px-8 py-4 font-mono text-[10px] text-white/30" style="border-color: rgba(20,184,166,0.10);">
            After purchase → <a href="/checkout-success" class="underline underline-offset-2 hover:text-white/50 transition-colors">see what happens next</a>.
            Questions? <a href="/contact" class="underline underline-offset-2 hover:text-white/50 transition-colors">Contact us.</a>
          </div>
        </div>
      ))}
    </div>
  </section>


  <!-- Live tools -->
  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="font-mono text-[10px] text-teal-400/45 uppercase tracking-widest mb-6">// available_now</p>

      <!-- Health Indicator Calculator Suite -->
      <div data-reveal
           class="relative rounded-3xl [backdrop-filter:blur(22px)] border border-teal-500/25 overflow-hidden mb-6"
           style="background: linear-gradient(145deg, rgba(20,184,166,0.10) 0%, rgba(10,13,18,0.92) 55%, rgba(20,184,166,0.04) 100%); box-shadow: 0 22px 56px -8px rgba(0,0,0,0.62), 0 0 52px -10px rgba(20,184,166,0.25), inset 0 1.5px 0 rgba(255,255,255,0.11), inset 0 -2px 8px rgba(0,0,0,0.30);">
        <div aria-hidden="true" class="absolute top-0 left-10 right-10 h-px" style="background: linear-gradient(90deg, transparent, rgba(20,184,166,0.55), transparent);"></div>
        <div class="p-8">
          <div class="flex flex-col lg:flex-row gap-8 items-start">

            <!-- Screenshot -->
            <div class="flex-shrink-0 w-full lg:w-56 h-40 rounded-xl overflow-hidden border border-teal-500/20">
              <img src="/images/blog/health-indicator-calculator-suite/health-indicator-calculator-suite.png" alt="Health Indicator Calculator Suite — report context, 55 indicators, DHIS2 auto-import" class="w-full h-full object-cover" loading="lazy" />
            </div>

            <!-- Info -->
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-3">
                <span class="font-mono px-2.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
                      style="background: rgba(20,184,166,0.15); border: 1px solid rgba(20,184,166,0.32); color: rgba(94,234,212,0.9);">[ LIVE ]</span>
                <span class="font-mono text-white/30 text-[10px]">v1.1 · Web app · 55 indicators · $79 one-time / $29·mo / $299·mo</span>
              </div>
              <h2 class="font-display font-bold text-2xl text-white mb-3">Health Indicator Calculator Suite</h2>
              <p class="text-white/60 text-sm leading-relaxed mb-5">
                Compute 55 WHO / UNICEF / Global Fund / PEPFAR indicators across six domains —
                coverage &amp; EPI, HIV/TB/Malaria, mortality, nutrition, utilisation, and data quality.
                Upload a raw DHIS2 / HMIS pivot export and it auto-detects and analyses every facility
                with no manual mapping, benchmarks each result against editable targets with paste-ready
                interpretation, and exports report-ready Excel / CSV. Built and tested in a Mamfe DMO office.
              </p>
              <ul class="space-y-2 mb-6">
                {[
                  '55 WHO / UNICEF / Global Fund / PEPFAR indicators across six domains',
                  'Auto-imports raw DHIS2 / HMIS pivot exports — no manual mapping',
                  'Benchmarked against editable national targets, with paste-ready interpretation',
                  'Bulk multi-facility computation + custom indicator builder',
                  'Excel / CSV export on every result',
                  'Free Lite version for practitioners — coming soon',
                ].map(item => (
                  <li class="flex items-start gap-2.5 text-sm text-white/65">
                    <svg class="w-4 h-4 text-teal-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
              <div class="flex flex-col sm:flex-row gap-3">
                <a
                  href="https://fieldhealth-indicators-tb4zamjekmwxqjotcc4tbi.streamlit.app"
                  target="_blank"
                  rel="noopener noreferrer"
                  class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-teal-500 to-emerald-500 hover:from-teal-400 hover:to-emerald-400 text-black font-bold text-sm transition-all duration-200 hover:shadow-[0_0_24px_rgba(20,184,166,0.4)]"
                >
                  Launch the tool →
                </a>
                <span class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-white/10 border border-white/15 text-white/40 font-bold text-sm cursor-not-allowed">
                  Free Lite version — coming soon
                </span>
              </div>
            </div>
          </div>
        </div>
        <div class="border-t px-8 py-4 flex flex-wrap gap-4 font-mono text-[10px] text-white/30" style="border-color: rgba(20,184,166,0.10);">
          <span>[ web ] Opens in browser · No installation</span>
          <span>[ data ] DHIS2 / HMIS auto-import</span>
          <span>[ pricing ] $79 one-time · $29/mo · $299/mo institutional</span>
          <span>[ pay ] MTN MoMo · Orange Money · Card</span>
        </div>
      </div>

      <!-- MINSANTE v3 -->
      <div data-reveal
           class="relative rounded-3xl [backdrop-filter:blur(22px)] border border-teal-500/25 overflow-hidden"
           style="background: linear-gradient(145deg, rgba(20,184,166,0.10) 0%, rgba(10,13,18,0.92) 55%, rgba(20,184,166,0.04) 100%); box-shadow: 0 22px 56px -8px rgba(0,0,0,0.62), 0 0 52px -10px rgba(20,184,166,0.25), inset 0 1.5px 0 rgba(255,255,255,0.11), inset 0 -2px 8px rgba(0,0,0,0.30);">
        <div aria-hidden="true" class="absolute top-0 left-10 right-10 h-px" style="background: linear-gradient(90deg, transparent, rgba(20,184,166,0.55), transparent);"></div>
        <div class="p-8">
          <div class="flex flex-col lg:flex-row gap-8 items-start">

            <!-- Screenshot -->
            <div class="flex-shrink-0 w-full lg:w-56 h-40 rounded-xl overflow-hidden border border-teal-500/20">
              <img src="/images/blog/MINSANTE_v3_GestionFinanciere_2/MINSANTE_v3_GestionFinanciere_2.png" alt="MINSANTE v3 Gestion Financière screenshot" class="w-full h-full object-cover" loading="lazy" />
            </div>

            <!-- Info -->
            <div class="flex-1">
              <div class="flex items-center gap-2 mb-3">
                <span class="font-mono px-2.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
                      style="background: rgba(20,184,166,0.15); border: 1px solid rgba(20,184,166,0.32); color: rgba(94,234,212,0.9);">[ LIVE ]</span>
                <span class="font-mono text-white/30 text-[10px]">v3 · HTML · Bilingual FR / EN · 10,000 FCFA</span>
              </div>
              <h2 class="font-display font-bold text-2xl text-white mb-3">MINSANTE v3 — Outil de Gestion Financière</h2>
              <p class="text-white/60 text-sm leading-relaxed mb-5">
                Complete financial management tool for Category 3–5 health facilities in Cameroon.
                Automates the 6-step Recettes Propres calculation, decade-by-decade Treasury deposits,
                6-way triangulation audit, and generates a print-ready official report — all in a single
                offline HTML file. Built from field requests. Compliant with Décret 2016/6447/PM and RGCP.
              </p>
              <ul class="space-y-2 mb-6">
                {[
                  'Single offline HTML file — no installation, no internet required',
                  '10 modules: Dashboard, Registers, Cash Journal, Treasury, Solidarity, Pharmacy, Expenditures, QP, Triangulation, Report',
                  'Monthly Grid view + decade-aware Treasury and Solidarity tables',
                  'Period-flexible triangulation (monthly, range, or full year)',
                  'CSV / Excel export on every module',
                  'Bilingual user guide (FR / EN) included',
                ].map(item => (
                  <li class="flex items-start gap-2.5 text-sm text-white/65">
                    <svg class="w-4 h-4 text-teal-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
                    {item}
                  </li>
                ))}
              </ul>
              <a
                href="/tools/minsante-v3/"
                class="inline-flex items-center gap-2 px-6 py-3 rounded-full bg-gradient-to-r from-teal-500 to-emerald-500 hover:from-teal-400 hover:to-emerald-400 text-black font-bold text-sm transition-all duration-200 hover:shadow-[0_0_24px_rgba(20,184,166,0.4)]"
              >
                Get MINSANTE v3 — 10,000 FCFA →
              </a>
            </div>
          </div>
        </div>
        <div class="border-t px-8 py-4 flex flex-wrap gap-4 font-mono text-[10px] text-white/30" style="border-color: rgba(20,184,166,0.10);">
          <span>[ web ] Opens in browser · No installation</span>
          <span>[ i18n ] Bilingual FR / EN</span>
          <span>[ compliant ] Décret 2016/6447/PM</span>
          <span>[ pay ] MTN MoMo · Orange Money</span>
        </div>
      </div>
    </div>
  </section>

  <!-- In development -->
  <section class="py-8 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="font-mono text-[10px] text-teal-400/40 uppercase tracking-widest mb-6">// in_development</p>
      <div data-reveal class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        {inDevelopment.map(({ title, desc }) => (
          <div class="rounded-2xl border border-white/[0.06] p-5 opacity-55 relative overflow-hidden"
               style="background: rgba(255,255,255,0.02);">
            <div class="absolute inset-0 opacity-[0.025]" style="background-image: repeating-linear-gradient(45deg, white, white 1px, transparent 1px, transparent 8px);" aria-hidden="true"></div>
            <div class="relative">
              <p class="font-mono text-[9px] text-teal-400/35 uppercase tracking-widest mb-3">[ IN_DEVELOPMENT ]</p>
              <h3 class="font-display font-bold text-base text-white/70 mb-1.5">{title}</h3>
              <p class="text-white/40 text-xs leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>


  <!-- Notify me -->
  <section class="py-12 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-2xl">
      <div class="relative rounded-3xl [backdrop-filter:blur(22px)] border border-teal-500/20 overflow-hidden p-8 text-center"
           style="background: linear-gradient(145deg, rgba(20,184,166,0.09) 0%, rgba(10,13,18,0.92) 55%, rgba(20,184,166,0.03) 100%); box-shadow: 0 18px 44px -8px rgba(0,0,0,0.58), 0 0 40px -10px rgba(20,184,166,0.20), inset 0 1.5px 0 rgba(255,255,255,0.10), inset 0 -2px 8px rgba(0,0,0,0.28);">
        <div aria-hidden="true" class="absolute top-0 left-10 right-10 h-px" style="background: linear-gradient(90deg, transparent, rgba(20,184,166,0.48), transparent);"></div>
        <p class="font-mono text-[9px] text-teal-400/45 uppercase tracking-widest mb-3">[ NOTIFY_ME ]</p>
        <h2 class="font-display font-bold text-xl text-white mb-2">Notify me when more Pro tools launch</h2>
        <p class="text-white/55 text-sm mb-6">Drop your email — we'll reach out before public launch, sometimes with an early-access discount.</p>

        <form
          action={NOTIFY_FORM}
          method="POST"
          class="flex flex-col sm:flex-row gap-3 max-w-sm mx-auto"
          id="notify-form"
        >
          <input type="hidden" name="_subject" value="Pro Library Notify Me" />
          <input type="text" name="_gotcha" class="hidden" tabindex="-1" autocomplete="off" />
          <label for="notify-email" class="sr-only">Email address</label>
          <input
            id="notify-email"
            name="email"
            type="email"
            required
            placeholder="your@email.com"
            class="flex-1 px-4 py-2.5 rounded-full bg-white/[0.05] border border-white/10 text-white placeholder-white/25 text-sm focus:outline-none focus:border-teal-500/60 focus:ring-1 focus:ring-teal-500/40 transition"
          />
          <button
            type="submit"
            class="px-6 py-2.5 rounded-full bg-gradient-to-r from-teal-500 to-emerald-500 hover:from-teal-400 hover:to-emerald-400 text-black font-bold text-sm transition-all duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-teal-300 focus-visible:outline-offset-2 whitespace-nowrap"
          >
            Notify me
          </button>
        </form>
        <p id="notify-thanks" class="text-teal-400 text-sm font-medium hidden mt-3">✓ You're on the list!</p>
      </div>
    </div>
  </section>

  <NewsletterBand />

</Base>

<script>
  const form = document.getElementById('notify-form') as HTMLFormElement | null;
  const thanks = document.getElementById('notify-thanks');
  if (form && thanks) {
    const action = form.action;
    if (!action.startsWith('[')) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        try {
          const res = await fetch(action, { method: 'POST', body: new FormData(form), headers: { Accept: 'application/json' } });
          if (res.ok) { form.classList.add('hidden'); thanks?.classList.remove('hidden'); }
        } catch {
          // Network error — silently absorb; user can retry
        }
      });
    }
  }
</script>
