---
import Base from '../layouts/Base.astro';
import AuroraBackground from '../components/AuroraBackground.astro';
import DownloadGate from '../components/DownloadGate.astro';
import NewsletterBand from '../components/NewsletterBand.astro';

const DOWNLOADS_FORM = 'https://formspree.io/f/mbdbayry';

const comingSoon = [
  { title: 'Health Indicator Calculator Lite',   desc: 'Instant district-level health indicator computation — mortality rates, coverage, ratios — with automated interpretation flags.' },
  { title: 'Outbreak Investigation Checklist',   desc: 'Field-tested outbreak response checklist covering line listing, case definitions, hypothesis generation, and reporting templates.' },
  { title: 'Antenatal Care Tracker',             desc: 'Monthly ANC attendance and drop-off tracking dashboard with facility-level comparisons and trend analysis.' },
  { title: 'DHIS2 Data Quality Auditor',         desc: 'Automated completeness and consistency checks for DHIS2 exports — flags duplicates, gaps, and implausible values.' },
  { title: 'Vaccination Coverage Calculator',    desc: 'Coverage and equity analysis tool for EPI campaigns, compatible with KoboToolbox exports and manual entry.' },
  { title: 'Facility Performance Scorecard',     desc: 'Monthly scorecard comparing facilities on key indicators with traffic-light scoring and district-level roll-up.' },
];
---

<Base
  title="Free Library"
  description="Practical digital health tools for African practitioners — no payment wall, no signup wall. Download free Excel dashboards, SOPs, and calculators built in the district."
>

  <!-- Hero -->
  <section class="relative py-24 px-4 sm:px-6 lg:px-8 overflow-hidden">
    <AuroraBackground variant="b" />
    <div aria-hidden="true" class="absolute inset-0 z-[1] pointer-events-none"
         style="background-image: radial-gradient(rgba(6,182,212,0.07) 1px, transparent 1px); background-size: 28px 28px; mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%); -webkit-mask-image: radial-gradient(ellipse 80% 80% at 50% 50%, black 30%, transparent 100%);"></div>
    <div class="relative z-10 mx-auto max-w-3xl">
      <div class="inline-flex items-center gap-2.5 mb-8">
        <div class="w-8 h-px bg-cyan-400/60" aria-hidden="true"></div>
        <span class="font-mono text-cyan-300/70 text-[11px] uppercase tracking-widest">// free_library</span>
      </div>
      <h1 class="font-display font-bold text-4xl sm:text-5xl lg:text-6xl text-white leading-tight mb-6">
        Practical tools,<br />
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 to-emerald-300">no payment, no signup wall.</span>
      </h1>
      <p class="text-white/65 text-lg leading-relaxed">
        Every tool here was built to solve a real problem in a real district. Download, adapt, use. If it helps — tell a colleague.
      </p>
    </div>
  </section>


  <!-- Live tools -->
  <section class="py-4 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl space-y-6">
      <p class="font-mono text-[10px] text-cyan-400/45 uppercase tracking-widest">// available_now</p>

      <!-- ── Tool 1: Pharmacy Inventory Tracker v2.1 (cyan) ── -->
      <div data-reveal
           class="relative rounded-3xl [backdrop-filter:blur(22px)] border border-cyan-500/20 overflow-hidden"
           style="background: linear-gradient(145deg, rgba(6,182,212,0.10) 0%, rgba(10,13,18,0.92) 55%, rgba(6,182,212,0.04) 100%); box-shadow: 0 22px 56px -8px rgba(0,0,0,0.62), 0 0 48px -10px rgba(6,182,212,0.25), inset 0 1.5px 0 rgba(255,255,255,0.11), inset 0 -2px 8px rgba(0,0,0,0.30);">
        <div aria-hidden="true" class="absolute top-0 left-10 right-10 h-px" style="background: linear-gradient(90deg, transparent, rgba(6,182,212,0.55), transparent);"></div>
        <div class="p-8">
          <div class="flex flex-col sm:flex-row gap-6 items-start">

            <div class="flex-shrink-0 w-full sm:w-52 h-36 rounded-xl overflow-hidden border border-cyan-500/20">
              <img src="/images/blog/pharmacy-inventory-v2/image.jpg" alt="Pharmacy Inventory Tracker v2.1 screenshot" class="w-full h-full object-cover" loading="lazy" />
            </div>

            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <span class="font-mono px-2.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
                      style="background: rgba(6,182,212,0.15); border: 1px solid rgba(6,182,212,0.28); color: rgba(103,232,249,0.9);">[ LIVE ]</span>
                <span class="font-mono text-white/30 text-[10px]">v2.1 · Excel + PDF guide</span>
              </div>
              <h2 class="font-display font-bold text-2xl text-white mb-2">Pharmacy Inventory Tracker v2.1</h2>
              <p class="text-white/60 text-sm leading-relaxed mb-6">
                Built and refined over 18 months of actual use in the Mamfe health district.
                Tracks stock levels across multiple drugs, flags items below safety stock,
                forecasts run-out dates before the next resupply, and highlights overdue orders.
                Includes the full User Guide.
              </p>
              <DownloadGate
                productName="Pharmacy Inventory Tracker v2.1"
                formEndpoint={DOWNLOADS_FORM}
                files={[
                  { label: 'Pharmacy Inventory v2.1 (.xlsx)', href: '/downloads/FieldHealth_Pharmacy_Inventory_v2.1.xlsx',            icon: 'xlsx' },
                  { label: 'User Guide (.pdf)',                href: '/downloads/FieldHealth_Pharmacy_Inventory_v2.1_User_Guide.pdf', icon: 'pdf'  },
                ]}
              />
            </div>
          </div>
        </div>
        <div class="border-t px-8 py-4 flex flex-wrap gap-4 font-mono text-[10px] text-white/35" style="border-color: rgba(6,182,212,0.10);">
          <span>[ offline ] Works offline · No macros required</span>
          <span>[ field ] Designed for low-bandwidth environments</span>
          <span>[ tested ] Mamfe health district, Cameroon</span>
        </div>
      </div>

      <!-- ── Tool 2: RH Data Quality Performance Review Tool v1.1 (amber) ── -->
      <div data-reveal data-reveal-delay="80"
           class="relative rounded-3xl [backdrop-filter:blur(22px)] border border-amber-500/20 overflow-hidden"
           style="background: linear-gradient(145deg, rgba(245,158,11,0.09) 0%, rgba(10,13,18,0.92) 55%, rgba(245,158,11,0.03) 100%); box-shadow: 0 22px 56px -8px rgba(0,0,0,0.62), 0 0 48px -10px rgba(245,158,11,0.18), inset 0 1.5px 0 rgba(255,255,255,0.10), inset 0 -2px 8px rgba(0,0,0,0.30);">
        <div aria-hidden="true" class="absolute top-0 left-10 right-10 h-px" style="background: linear-gradient(90deg, transparent, rgba(245,158,11,0.48), transparent);"></div>
        <div class="p-8">
          <div class="flex flex-col sm:flex-row gap-6 items-start">

            <div class="flex-shrink-0 w-full sm:w-52 h-36 rounded-xl overflow-hidden border border-amber-500/20">
              <img src="/images/blog/reproductive-health-data-quality/Screenshot%202026-05-25%20201715.png" alt="RH Data Quality Performance Review Tool screenshot" class="w-full h-full object-cover" loading="lazy" />
            </div>

            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <span class="font-mono px-2.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
                      style="background: rgba(245,158,11,0.15); border: 1px solid rgba(245,158,11,0.28); color: rgba(252,211,77,0.9);">[ LIVE ]</span>
                <span class="font-mono text-white/30 text-[10px]">v1.1 · Excel + PDF guide</span>
              </div>
              <h2 class="font-display font-bold text-2xl text-white mb-2">RH Data Quality Performance Review Tool v1.1</h2>
              <p class="text-white/60 text-sm leading-relaxed mb-6">
                Systematic data quality and performance review tool for district HR officers.
                Flags completeness and accuracy gaps across facility-level health records,
                scores each facility against national benchmarks, and generates a consolidated
                summary report ready for district review meetings.
              </p>
              <DownloadGate
                productName="RH Data Quality Performance Review Tool v1.1"
                formEndpoint={DOWNLOADS_FORM}
                files={[
                  { label: 'RH Performance Review v1.1 (.xlsx)', href: '/downloads/RH_Data_Quality_Performance_Review_Tool_p_v1.1.xlsx',    icon: 'xlsx' },
                  { label: 'User Guide (.pdf)',                    href: '/downloads/RH_Data_Quality_Performance_Review_Tool_User_Guide_v1.pdf', icon: 'pdf'  },
                ]}
              />
            </div>
          </div>
        </div>
        <div class="border-t px-8 py-4 flex flex-wrap gap-4 font-mono text-[10px] text-white/35" style="border-color: rgba(245,158,11,0.10);">
          <span>[ offline ] Works offline · No macros required</span>
          <span>[ score ] Facility-level scoring against national benchmarks</span>
          <span>[ report ] District review–ready summary output</span>
        </div>
      </div>

      <!-- ── Tool 3: MINSANTE v2 Gestion Financière (violet) ── -->
      <div data-reveal data-reveal-delay="160"
           class="relative rounded-3xl [backdrop-filter:blur(22px)] border border-violet-500/20 overflow-hidden"
           style="background: linear-gradient(145deg, rgba(139,92,246,0.09) 0%, rgba(10,13,18,0.92) 55%, rgba(139,92,246,0.03) 100%); box-shadow: 0 22px 56px -8px rgba(0,0,0,0.62), 0 0 48px -10px rgba(139,92,246,0.18), inset 0 1.5px 0 rgba(255,255,255,0.10), inset 0 -2px 8px rgba(0,0,0,0.30);">
        <div aria-hidden="true" class="absolute top-0 left-10 right-10 h-px" style="background: linear-gradient(90deg, transparent, rgba(139,92,246,0.48), transparent);"></div>
        <div class="p-8">
          <div class="flex flex-col sm:flex-row gap-6 items-start">

            <div class="flex-shrink-0 w-full sm:w-52 h-36 rounded-xl overflow-hidden border border-violet-500/20">
              <img src="/images/blog/financial-management-tool/image%20(1).jpg" alt="MINSANTE v2 Gestion Financière screenshot" class="w-full h-full object-cover" loading="lazy" />
            </div>

            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-2">
                <span class="font-mono px-2.5 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-wider"
                      style="background: rgba(139,92,246,0.15); border: 1px solid rgba(139,92,246,0.28); color: rgba(196,181,253,0.9);">[ LIVE ]</span>
                <span class="font-mono text-white/30 text-[10px]">v2 · Web (HTML) · Bilingual FR / EN</span>
              </div>
              <h2 class="font-display font-bold text-2xl text-white mb-2">MINSANTE v2 — Gestion Financière</h2>
              <p class="text-white/60 text-sm leading-relaxed mb-6">
                Web-based financial management dashboard built to MINSANTE specifications.
                Tracks budget allocations, actual expenditures, and variance analysis at facility
                and district level. Fully bilingual (French / English). Opens directly in any
                browser — no Excel, no installation required.
              </p>
              <DownloadGate
                productName="MINSANTE v2 Gestion Financière"
                formEndpoint={DOWNLOADS_FORM}
                files={[
                  { label: 'MINSANTE Gestion Financière v2 (.html)', href: '/downloads/MINSANTE_v2_GestionFinanciere%20(1).html', icon: 'html' },
                  { label: 'Guide Utilisateur FR (.pdf)',             href: '/downloads/Guide_Utilisateur_FR_v2.pdf',              icon: 'pdf'  },
                  { label: 'User Guide EN (.pdf)',                    href: '/downloads/UserGuide_EN_v2.pdf',                      icon: 'pdf'  },
                ]}
              />
            </div>
          </div>
        </div>
        <div class="border-t px-8 py-4 flex flex-wrap gap-4 font-mono text-[10px] text-white/35" style="border-color: rgba(139,92,246,0.10);">
          <span>[ web ] Opens in browser · No installation required</span>
          <span>[ i18n ] Bilingual FR / EN</span>
          <span>[ compliant ] Built to MINSANTE specifications</span>
        </div>
      </div>

    </div>
  </section>


  <!-- Coming soon cards -->
  <section class="py-16 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <p class="font-mono text-[10px] text-cyan-400/45 uppercase tracking-widest mb-6">// coming_soon</p>
      <div data-reveal class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {comingSoon.map(({ title, desc }) => (
          <div class="rounded-2xl border border-white/[0.06] p-5 opacity-55 relative overflow-hidden"
               style="background: rgba(255,255,255,0.02);">
            <div class="absolute inset-0 opacity-[0.025]" style="background-image: repeating-linear-gradient(45deg, white, white 1px, transparent 1px, transparent 8px);" aria-hidden="true"></div>
            <div class="relative">
              <p class="font-mono text-[9px] text-white/30 uppercase tracking-widest mb-3">[ COMING_SOON ]</p>
              <h3 class="font-display font-bold text-base text-white/70 mb-1.5">{title}</h3>
              <p class="text-white/40 text-xs leading-relaxed">{desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <NewsletterBand />

</Base>
