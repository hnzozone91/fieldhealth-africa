---
import Base from '../layouts/Base.astro';
import AuroraBackground from '../components/AuroraBackground.astro';
import GlassCard from '../components/GlassCard.astro';
import NewsletterBand from '../components/NewsletterBand.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);
---

<Base
  title="Home"
  description="Practical digital health tools built and tested by African practitioners. Free Library for health workers · Pro tools for global consultants · Picks from the field."
>

  <!-- ════════════════════════════════════════════
       HERO — Direction B: Aurora Signal
       ════════════════════════════════════════════ -->
  <section class="relative min-h-[92vh] flex items-center overflow-hidden" style="background-color:#0f0f14">
    <AuroraBackground variant="b" parallax={true} />

    <div id="hero-content" class="relative z-10 w-full px-6 sm:px-12 lg:px-20 max-w-7xl mx-auto py-20">
      <div class="max-w-3xl">

        <!-- Eyebrow -->
        <div class="inline-flex items-center gap-2.5 mb-10 animate-fade-up" style="animation-delay:0.05s">
          <div class="w-8 h-px bg-cyan-400/60" aria-hidden="true"></div>
          <span class="text-cyan-300/80 text-xs font-semibold uppercase tracking-widest">FieldHealth Africa</span>
        </div>

        <!-- Headline -->
        <h1 class="font-display font-bold text-5xl sm:text-6xl lg:text-7xl xl:text-8xl text-white leading-[1.0] tracking-tight animate-fade-up" style="animation-delay:0.1s">
          From data<br />
          to decisions,<br />
          <span class="relative inline-block">
            <span class="text-transparent bg-clip-text bg-gradient-to-r from-cyan-300 via-teal-200 to-emerald-300">
              in the field.
            </span>
            <span class="absolute inset-0 blur-2xl opacity-30 bg-gradient-to-r from-cyan-400 via-teal-300 to-emerald-400 -z-10" aria-hidden="true"></span>
          </span>
        </h1>

        <p class="mt-7 text-lg sm:text-xl text-white/70 max-w-xl leading-relaxed animate-fade-up" style="animation-delay:0.18s">
          Practical digital health tools built and tested by African practitioners —
          free for health workers, premium for global consultants.
        </p>

        <div class="mt-10 flex flex-col sm:flex-row gap-4 animate-fade-up" style="animation-delay:0.26s">
          <a
            href="/free-library"
            class="group inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full bg-gradient-to-r from-cyan-500 to-teal-500 hover:from-cyan-400 hover:to-teal-400 text-black font-bold text-base transition-all duration-200 hover:shadow-[0_0_32px_rgba(6,182,212,0.45)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-300 focus-visible:outline-offset-2"
          >
            Browse the Free Library
            <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
          </a>
          <a
            href="/pro-library"
            class="inline-flex items-center justify-center gap-2 px-8 py-4 rounded-full border border-white/20 text-white font-semibold text-base hover:border-white/35 hover:bg-white/[0.05] transition-all duration-200 backdrop-blur-sm focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-300 focus-visible:outline-offset-2"
          >
            Explore Pro Tools
          </a>
        </div>

        <!-- Stats -->
        <div class="mt-14 flex flex-wrap gap-8 animate-fade-up" style="animation-delay:0.34s">
          {[
            { n: '7',  label: 'Peer-reviewed publications' },
            { n: '1',  label: 'Live free tool'             },
            { n: '1',  label: 'Live pro tool'              },
          ].map(({ n, label }) => (
            <div>
              <p class="font-display font-bold text-3xl text-white">{n}</p>
              <p class="text-white/40 text-xs mt-0.5">{label}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════
       THREE LIBRARY CARDS
       ════════════════════════════════════════════ -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <h2 data-reveal class="text-center font-display font-bold text-3xl sm:text-4xl text-white mb-4">Everything in one place</h2>
      <p data-reveal data-reveal-delay="100" class="text-center text-white/50 mb-12 max-w-xl mx-auto text-sm">Two libraries and a curated picks page — built around what practitioners actually need.</p>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-5">

        <a data-reveal data-reveal-delay="100" href="/free-library" class="group rounded-2xl bg-gradient-to-br from-white/[0.08] to-white/[0.03] [backdrop-filter:blur(18px)] border border-white/[0.13] ring-1 ring-cyan-500/20 shadow-[0_0_30px_-6px_rgba(6,182,212,0.18)] p-6 flex flex-col transition-all duration-300 hover:bg-white/[0.07] hover:ring-cyan-400/35 hover:shadow-[0_0_40px_-4px_rgba(6,182,212,0.28)] hover:scale-[1.015] focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400 focus-visible:outline-offset-2">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-500/20 to-teal-500/10 border border-cyan-500/20 flex items-center justify-center mb-5 group-hover:border-cyan-400/35 transition-colors" aria-hidden="true">
            <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-2">Free Library</h3>
          <p class="text-white/55 text-sm leading-relaxed flex-1">Practical tools for African health workers — Excel dashboards, SOPs, and calculators tested in the district. No payment wall.</p>
          <div class="mt-5 flex items-center gap-1 text-cyan-400 text-sm font-medium">Browse free tools <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></div>
        </a>

        <a data-reveal data-reveal-delay="200" href="/pro-library" class="group relative rounded-2xl bg-gradient-to-b from-white/[0.07] to-white/[0.03] backdrop-blur-md border border-white/[0.15] ring-1 ring-teal-400/30 shadow-[0_0_36px_-4px_rgba(20,184,166,0.28)] p-6 flex flex-col transition-all duration-300 hover:ring-teal-300/45 hover:shadow-[0_0_48px_-4px_rgba(20,184,166,0.38)] hover:scale-[1.015] focus-visible:outline focus-visible:outline-2 focus-visible:outline-teal-400 focus-visible:outline-offset-2">
          <div class="absolute top-4 right-4 px-2.5 py-0.5 rounded-full bg-teal-500/15 border border-teal-400/30 text-teal-300 text-[10px] font-bold uppercase tracking-wider">Pro</div>
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-teal-500/20 to-emerald-500/10 border border-teal-500/20 flex items-center justify-center mb-5 group-hover:border-teal-400/35 transition-colors" aria-hidden="true">
            <svg class="w-6 h-6 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-2">Pro Library</h3>
          <p class="text-white/55 text-sm leading-relaxed flex-1">Premium Python apps, AI-powered dashboards, and predictive tools for NGO M&E teams, global health consultants, and researchers.</p>
          <div class="mt-5 flex items-center gap-1 text-teal-300 text-sm font-medium">Explore Pro tools <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></div>
        </a>

        <a data-reveal data-reveal-delay="300" href="/picks" class="group rounded-2xl bg-gradient-to-br from-white/[0.08] to-white/[0.03] [backdrop-filter:blur(18px)] border border-white/[0.13] ring-1 ring-indigo-500/20 shadow-[0_0_30px_-6px_rgba(99,102,241,0.18)] p-6 flex flex-col transition-all duration-300 hover:bg-white/[0.07] hover:ring-indigo-400/35 hover:shadow-[0_0_40px_-4px_rgba(99,102,241,0.28)] hover:scale-[1.015] focus-visible:outline focus-visible:outline-2 focus-visible:outline-indigo-400 focus-visible:outline-offset-2">
          <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-indigo-500/20 to-purple-500/10 border border-indigo-500/20 flex items-center justify-center mb-5 group-hover:border-indigo-400/35 transition-colors" aria-hidden="true">
            <svg class="w-6 h-6 text-indigo-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z"/></svg>
          </div>
          <h3 class="font-display font-bold text-xl text-white mb-2">Picks</h3>
          <p class="text-white/55 text-sm leading-relaxed flex-1">Tools I actually use — curated for healthcare workers, data analysts, and builders. Affiliate links disclosed.</p>
          <div class="mt-5 flex items-center gap-1 text-indigo-400 text-sm font-medium">See recommendations <svg class="w-4 h-4 group-hover:translate-x-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg></div>
        </a>

      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════
       FOUNDER TEASER
       ════════════════════════════════════════════ -->
  <section class="py-4 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-4xl">
      <div data-reveal class="rounded-2xl bg-gradient-to-br from-white/[0.08] to-white/[0.03] [backdrop-filter:blur(18px)] border border-white/[0.13] ring-1 ring-cyan-500/20 shadow-[0_0_30px_-6px_rgba(6,182,212,0.15)] overflow-hidden p-8">
        <div class="flex flex-col sm:flex-row gap-8 items-start">

          <!-- Photo -->
          <div class="flex-shrink-0 w-28 h-28 sm:w-36 sm:h-36 rounded-2xl bg-gradient-to-br from-cyan-900/50 to-teal-900/30 border border-cyan-500/20 overflow-hidden">
            <img
              src="/images/founder.jpeg"
              alt="Dr. Nzozone Henry Fomukong, founder of FieldHealth Africa"
              width="144" height="144"
              class="w-full h-full object-cover"
              loading="lazy"
              onerror="this.style.display='none'"
            />
          </div>

          <!-- Bio -->
          <div class="flex-1 min-w-0">
            <p class="text-cyan-400 text-xs font-semibold uppercase tracking-widest mb-2">About the founder</p>
            <h2 class="font-display font-bold text-2xl text-white mb-3">Dr. Nzozone Henry Fomukong</h2>
            <p class="text-white/65 text-sm leading-relaxed mb-4">
              Medical doctor, field epidemiologist, and District Medical Officer in Mamfe, Cameroon — one of Central Africa's most demanding operational settings.
              Author of seven peer-reviewed publications, holder of a Data Science &amp; ML diploma from IDSS, and active practitioner of Python, DHIS2, and AI-assisted workflows.
              FieldHealth Africa is built to convert that experience into tools that travel.
            </p>
            <a href="/about" class="inline-flex items-center gap-1.5 text-cyan-400 hover:text-cyan-300 text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400 rounded">
              Read the full story
              <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════
       LATEST FROM THE BLOG
       ════════════════════════════════════════════ -->
  <section class="py-20 px-4 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <div data-reveal class="flex items-center justify-between mb-10">
        <h2 class="font-display font-bold text-3xl text-white">Latest from the blog</h2>
        <a href="/blog" class="text-cyan-400 hover:text-cyan-300 text-sm font-medium transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400 rounded">All posts →</a>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        {posts.length > 0 ? posts.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="group rounded-2xl bg-gradient-to-br from-white/[0.08] to-white/[0.03] [backdrop-filter:blur(18px)] border border-white/[0.13] ring-1 ring-white/[0.06] p-6 flex flex-col transition-all duration-300 hover:bg-white/[0.07] hover:scale-[1.015] focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400 focus-visible:outline-offset-2"
          >
            <span class="text-cyan-400 text-xs font-semibold uppercase tracking-widest mb-3">{post.data.tags[0] ?? 'Field Notes'}</span>
            <h3 class="font-display font-bold text-lg text-white mb-2 leading-snug">{post.data.title}</h3>
            <p class="text-white/55 text-sm leading-relaxed flex-1">{post.data.description}</p>
            <p class="text-white/30 text-xs mt-4">{post.data.pubDate.toLocaleDateString('en-GB', { month: 'long', year: 'numeric' })}</p>
          </a>
        )) : (
          [
            { tag: 'Free Library', title: 'Introducing Pharmacy Inventory v2.1', excerpt: 'How a simple Excel dashboard helps district pharmacists prevent stock-outs.', date: 'May 2026', href: '/blog/pharmacy-inventory-v2' },
            { tag: 'Field Notes',  title: 'What 8 Years as a DMO Taught Me About Data', excerpt: 'The gap between what health systems collect and what field teams need.', date: 'TODO', href: '/blog' },
            { tag: 'Pro Tools',   title: 'Predicting Drug Stock-Outs Before They Happen', excerpt: 'Methodology behind our predictive model — inputs, outputs, limitations.', date: 'TODO', href: '/blog' },
          ].map((p) => (
            <a href={p.href} class="group rounded-2xl bg-gradient-to-br from-white/[0.08] to-white/[0.03] [backdrop-filter:blur(18px)] border border-white/[0.13] ring-1 ring-white/[0.06] p-6 flex flex-col transition-all duration-300 hover:bg-white/[0.07] hover:scale-[1.015] focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400 focus-visible:outline-offset-2">
              <span class="text-cyan-400 text-xs font-semibold uppercase tracking-widest mb-3">{p.tag}</span>
              <h3 class="font-display font-bold text-lg text-white mb-2 leading-snug">{p.title}</h3>
              <p class="text-white/55 text-sm leading-relaxed flex-1">{p.excerpt}</p>
              <p class="text-white/30 text-xs mt-4">{p.date}</p>
            </a>
          ))
        )}
      </div>
    </div>
  </section>


  <!-- ════════════════════════════════════════════
       NEWSLETTER
       ════════════════════════════════════════════ -->
  <NewsletterBand />

</Base>

<!-- Hero content parallax — text moves at 15% of scroll speed (subtle depth) -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const el = document.getElementById('hero-content');
    if (el) {
      const heroHeight = el.closest('section')?.offsetHeight ?? 800;
      let raf: number | null = null;
      window.addEventListener('scroll', () => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          const y = Math.min(window.scrollY, heroHeight);
          el.style.transform = `translateY(${y * 0.14}px)`;
          raf = null;
        });
      }, { passive: true });
    }
  }
</script>

