---
/**
 * /checkout-success
 * Paystack callback target for successful payments.
 *
 * Set this as your Paystack Payment Link success/callback URL:
 *   https://fieldhealthafrica.org/checkout-success
 *
 * Paystack appends ?reference=TXN_REF to this URL.
 * The verify-payment CF Function stub (functions/api/verify-payment.ts)
 * is the upgrade path for server-side verification + auto-download.
 */
import Base from '../layouts/Base.astro';
---

<Base
  title="Payment Successful"
  description="Thank you for your purchase — your download instructions are on their way."
  noIndex={true}
>
  <div class="min-h-[80vh] flex items-center justify-center px-4 py-20">
    <div class="max-w-lg w-full text-center">

      <!-- No-reference fallback — shown when page is visited without a Paystack ?reference= param -->
      <div id="payment-error-card" class="hidden relative rounded-3xl [backdrop-filter:blur(22px)] border border-white/10 overflow-hidden p-10"
           style="background: rgba(10,13,18,0.93); box-shadow: 0 22px 56px -8px rgba(0,0,0,0.62);">
        <p class="font-mono text-[9px] text-white/30 uppercase tracking-widest mb-6">[ NO_REFERENCE ]</p>
        <h1 class="font-display font-bold text-2xl text-white mb-3">No payment reference found</h1>
        <p class="text-white/60 text-sm leading-relaxed mb-6">
          This page is only accessible after completing a purchase. If you've just paid,
          please use the link in your Paystack confirmation email to return here.
        </p>
        <a href="/pro-library" class="inline-flex items-center justify-center px-6 py-2.5 rounded-full bg-gradient-to-r from-teal-500 to-emerald-500 text-black font-bold text-sm">
          Go to Pro Library
        </a>
      </div>

      <!-- Success card — hidden by default, revealed by script only when ?reference= is present -->
      <div id="payment-success-card" class="hidden relative rounded-3xl [backdrop-filter:blur(22px)] border border-teal-500/25 overflow-hidden p-10"
           style="background: linear-gradient(145deg, rgba(20,184,166,0.12) 0%, rgba(10,13,18,0.93) 55%, rgba(20,184,166,0.05) 100%); box-shadow: 0 22px 56px -8px rgba(0,0,0,0.62), 0 0 52px -10px rgba(20,184,166,0.28), inset 0 1.5px 0 rgba(255,255,255,0.11), inset 0 -2px 8px rgba(0,0,0,0.30);">
        <div aria-hidden="true" class="absolute top-0 left-10 right-10 h-px" style="background: linear-gradient(90deg, transparent, rgba(20,184,166,0.55), transparent);"></div>

        <p class="font-mono text-[9px] text-teal-400/50 uppercase tracking-widest mb-6">[ PAYMENT_CONFIRMED ]</p>

        <!-- Success icon -->
        <div class="w-16 h-16 rounded-2xl flex items-center justify-center mx-auto mb-6" aria-hidden="true"
             style="background: linear-gradient(135deg, rgba(20,184,166,0.28) 0%, rgba(20,184,166,0.08) 100%); border: 1px solid rgba(20,184,166,0.30); box-shadow: 0 8px 22px -4px rgba(20,184,166,0.30), inset 0 1px 0 rgba(255,255,255,0.10);">
          <svg class="w-8 h-8 text-teal-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
          </svg>
        </div>

        <h1 class="font-display font-bold text-3xl text-white mb-3">Payment received!</h1>
        <p class="text-white/65 text-base leading-relaxed mb-8">
          Thank you for purchasing from FieldHealth Africa.
          <strong class="text-white">Check your email</strong> — your download link and receipt will arrive within a few minutes.
        </p>

        <!-- Steps card -->
        <div class="rounded-2xl border border-white/[0.07] p-5 text-left mb-8"
             style="background: rgba(255,255,255,0.03);">
          <p class="font-mono text-[9px] text-teal-400/50 uppercase tracking-widest mb-3">[ NEXT_STEPS ]</p>
          <ol class="space-y-2.5">
            {[
              'Check the email you used at checkout for a receipt from Paystack.',
              'A separate email from hello@fieldhealthafrica.org will follow within a few minutes with your download link.',
              'Download and open the tool. If you run into anything, reply to that email.',
            ].map((step, i) => (
              <li class="flex items-start gap-3 text-sm text-white/60">
                <span class="w-5 h-5 rounded-full flex items-center justify-center flex-shrink-0 mt-0.5 text-teal-300 text-[11px] font-bold font-mono"
                      style="background: rgba(20,184,166,0.15); border: 1px solid rgba(20,184,166,0.28);">{i + 1}</span>
                {step}
              </li>
            ))}
          </ol>
        </div>

        <p class="font-mono text-white/30 text-[10px] mb-6 tracking-wide">
          No email after 10 minutes? Check spam or contact{' '}
          <a href="mailto:hello@fieldhealthafrica.org" class="text-cyan-400/80 underline underline-offset-2 hover:text-cyan-300 transition-colors">hello@fieldhealthafrica.org</a>.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/pro-library" class="flex-1 inline-flex items-center justify-center py-2.5 rounded-full border border-white/15 text-white/60 hover:text-white hover:border-white/25 text-sm transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-400">
            Back to Pro Library
          </a>
          <a href="/" class="flex-1 inline-flex items-center justify-center py-2.5 rounded-full bg-gradient-to-r from-teal-500 to-emerald-500 hover:from-teal-400 hover:to-emerald-400 text-black font-bold text-sm transition-all hover:shadow-[0_0_20px_rgba(20,184,166,0.35)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-teal-300">
            Home
          </a>
        </div>

      </div>

    </div>
  </div>

  <script>
    // Require a Paystack ?reference= param to reveal the success card.
    // Without this guard, anyone can share the /checkout-success URL as fake proof of purchase.
    const ref = new URLSearchParams(location.search).get('reference');
    // Require reference to match Paystack's format — filters obvious fakes like ?reference=1
    const validRef = ref && /^[A-Za-z0-9_-]{8,64}$/.test(ref);
    const successCard = document.getElementById('payment-success-card');
    const errorCard   = document.getElementById('payment-error-card');
    if (validRef) {
      successCard?.classList.remove('hidden');
    } else {
      errorCard?.classList.remove('hidden');
    }
  </script>
</Base>
