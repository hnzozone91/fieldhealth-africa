---
/**
 * NewsletterBand.astro — reusable Substack CTA section.
 * Swap [SUBSTACK_SUBSCRIBE_URL] with real URL when available.
 */
---

<section class="py-20 px-4 sm:px-6 lg:px-8">
  <div class="mx-auto max-w-2xl text-center">
    <div class="rounded-2xl bg-gradient-to-br from-white/[0.08] to-white/[0.03] [backdrop-filter:blur(18px)] border border-white/[0.13] ring-1 ring-cyan-500/20 shadow-[0_0_36px_-4px_rgba(6,182,212,0.18)] p-10">
      <div class="w-12 h-12 rounded-2xl bg-gradient-to-br from-cyan-500/20 to-teal-500/10 border border-cyan-500/20 flex items-center justify-center mx-auto mb-6" aria-hidden="true">
        <svg class="w-6 h-6 text-cyan-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
        </svg>
      </div>
      <h2 class="font-display font-bold text-2xl sm:text-3xl text-white mb-3">
        New tools. Field notes. No noise.
      </h2>
      <p class="text-white/60 mb-8 leading-relaxed">
        Get notified when new tools launch and read dispatches from the district.
      </p>
      <!-- TODO: replace href with real Substack URL → https://[PUBLICATION].substack.com/subscribe -->
      <a
        href="[SUBSTACK_SUBSCRIBE_URL]"
        class="inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-full bg-gradient-to-r from-cyan-500 to-teal-500 hover:from-cyan-400 hover:to-teal-400 text-black font-bold text-base transition-all duration-200 hover:shadow-[0_0_28px_rgba(6,182,212,0.40)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-cyan-300 focus-visible:outline-offset-2"
      >
        Subscribe on Substack
      </a>
      <p class="text-white/30 text-xs mt-4">No spam. Unsubscribe any time.</p>
    </div>
  </div>
</section>

