---
/**
 * AffiliateDisclosure.astro — reusable disclosure callout.
 *
 * Props:
 *   compact? — smaller inline variant for blog posts / per-card use
 */
interface Props {
  compact?: boolean;
}
const { compact = false } = Astro.props;
---

{compact ? (
  <p class="text-white/35 text-xs leading-relaxed">
    <span class="font-semibold text-white/50">Affiliate link</span> — if you purchase through this link, FieldHealth Africa may earn a small commission at no extra cost to you.{' '}
    <a href="/affiliate-disclosure" class="underline underline-offset-2 hover:text-white/55 transition-colors">Full disclosure.</a>
  </p>
) : (
  <div class="rounded-2xl bg-amber-500/[0.06] border border-amber-500/20 p-5 flex gap-4 items-start">
    <svg class="w-5 h-5 text-amber-400 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
    </svg>
    <div>
      <p class="text-amber-300 font-semibold text-sm mb-1">Affiliate Disclosure</p>
      <p class="text-white/60 text-sm leading-relaxed">
        Some links on this page are affiliate links. If you purchase through one of them, FieldHealth Africa earns a small commission — at no extra cost to you.
        Every recommendation on this page is something Dr. Fomukong actually uses. We only list tools in the productivity, data, and learning categories.
        We never recommend clinical software, drug suppliers, or anything touching clinical decisions.{' '}
        <a href="/affiliate-disclosure" class="text-amber-300/80 underline underline-offset-2 hover:text-amber-300 transition-colors">Read the full disclosure.</a>
      </p>
    </div>
  </div>
)}
