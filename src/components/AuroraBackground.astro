---
/**
 * AuroraBackground.astro
 *
 * Animated mesh-gradient aurora.
 * - Three organic blobs with independent, differentiated motion paths
 * - Base gradient layer slowly shifts position (mesh-drift keyframe)
 * - Subtle hue-rotate on the base (colour cycling through palette)
 * - Scroll parallax: set parallax={true} on hero sections only
 * - Reduced-motion: all animation and parallax disabled via media query
 * - Performance: transforms + opacity only (GPU), one blur per blob, no stacking
 */
interface Props {
  variant?: 'a' | 'b';
  parallax?: boolean;
}
const { variant = 'b', parallax = false } = Astro.props;
const rootId = parallax ? 'aurora-parallax-root' : undefined;
---

<div class="aurora-root" id={rootId} data-variant={variant} aria-hidden="true">
  <div class="aurora-base"></div>
  <div class="aurora-blob blob-1"></div>
  <div class="aurora-blob blob-2"></div>
  <div class="aurora-blob blob-3"></div>
  <div class="aurora-blob blob-4"></div>
</div>

<style>
  .aurora-root {
    position: absolute;
    inset: -15% -5%;        /* bleed beyond edges so parallax doesn't clip */
    overflow: hidden;
    z-index: 0;
    pointer-events: none;
  }

  /* ─── Direction B base (used on all pages) ───────────────────────── */
  [data-variant='b'] .aurora-base {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 90% 70% at 15% 20%, rgba(6,182,212,0.52) 0%, transparent 65%),
      radial-gradient(ellipse 70% 60% at 88% 70%, rgba(99,102,241,0.44) 0%, transparent 65%),
      radial-gradient(ellipse 55% 45% at 55% 85%, rgba(52,211,153,0.34) 0%, transparent 65%),
      radial-gradient(ellipse 40% 35% at 80% 15%, rgba(6,182,212,0.24) 0%, transparent 65%);
    background-size: 180% 180%, 160% 160%, 140% 140%, 120% 120%;
    background-position: 0% 50%, 100% 50%, 50% 0%, 80% 20%;
    animation: mesh-drift 35s ease-in-out infinite, hue-cycle 50s ease-in-out infinite;
  }

  /* ─── Direction A base ───────────────────────────────────────────── */
  [data-variant='a'] .aurora-base {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 85% 65% at 20% 30%, rgba(13,148,136,0.38) 0%, transparent 65%),
      radial-gradient(ellipse 65% 55% at 82% 68%, rgba(16,185,129,0.28) 0%, transparent 65%),
      radial-gradient(ellipse 50% 40% at 50% 50%, rgba(59,130,246,0.15) 0%, transparent 65%);
    background-size: 180% 180%, 160% 160%, 140% 140%;
    background-position: 0% 50%, 100% 50%, 50% 0%;
    animation: mesh-drift 28s ease-in-out infinite;
  }

  /* ─── Shared blob geometry ─────────────────────────────────────────── */
  .aurora-blob {
    position: absolute;
    border-radius: 50%;          /* default for reduced-motion / fallback */
    filter: blur(72px);
    will-change: transform;
  }

  /* Blob 1 — large, upper-left, primary colour */
  .blob-1 {
    width: min(700px, 95vw);
    height: min(620px, 85vw);
    top: -12%;
    left: -8%;
  }
  [data-variant='b'] .blob-1 { background: radial-gradient(circle at 40% 40%, rgba(6,182,212,0.58) 0%, rgba(20,184,166,0.28) 45%, transparent 70%); }
  [data-variant='a'] .blob-1 { background: radial-gradient(circle at 40% 40%, rgba(13,148,136,0.55) 0%, transparent 70%); }

  /* Blob 2 — medium, lower-right, secondary colour */
  .blob-2 {
    width: min(560px, 78vw);
    height: min(500px, 70vw);
    bottom: -10%;
    right: -6%;
  }
  [data-variant='b'] .blob-2 { background: radial-gradient(circle at 60% 60%, rgba(99,102,241,0.50) 0%, rgba(59,130,246,0.22) 45%, transparent 70%); }
  [data-variant='a'] .blob-2 { background: radial-gradient(circle at 60% 60%, rgba(16,185,129,0.45) 0%, transparent 70%); }

  /* Blob 3 — medium accent, mid-centre, emerald */
  .blob-3 {
    width: min(400px, 60vw);
    height: min(340px, 52vw);
    top: 35%;
    left: 42%;
  }
  [data-variant='b'] .blob-3 { background: radial-gradient(circle at 50% 50%, rgba(52,211,153,0.36) 0%, rgba(6,182,212,0.14) 50%, transparent 70%); }
  [data-variant='a'] .blob-3 { background: radial-gradient(circle at 50% 50%, rgba(59,130,246,0.28) 0%, transparent 70%); }

  /* Blob 4 — small sparkle accent, upper-right */
  .blob-4 {
    width: min(260px, 42vw);
    height: min(220px, 36vw);
    top: 8%;
    right: 10%;
  }
  [data-variant='b'] .blob-4 { background: radial-gradient(circle at 50% 50%, rgba(6,182,212,0.28) 0%, transparent 70%); }
  [data-variant='a'] .blob-4 { background: radial-gradient(circle at 50% 50%, rgba(13,148,136,0.22) 0%, transparent 70%); }

  /* ─── Animations (all wrapped in motion-safe) ──────────────────────── */

  /* Mesh-drift: shifts the multi-layer gradient positions for a rippling effect */
  @media (prefers-reduced-motion: no-preference) {
    @keyframes mesh-drift {
      0%   { background-position: 0% 50%,  100% 50%, 50%  0%,  80%  20%; }
      20%  { background-position: 30% 70%, 70%  30%, 20%  70%, 60%  40%; }
      40%  { background-position: 80% 30%, 20%  70%, 75%  50%, 30%  60%; }
      60%  { background-position: 50% 80%, 50%  20%, 30%  80%, 70%  10%; }
      80%  { background-position: 20% 40%, 80%  60%, 60%  20%, 50%  70%; }
      100% { background-position: 0% 50%,  100% 50%, 50%  0%,  80%  20%; }
    }

    /* Hue-cycle: gently rotates hue ±20° for a colour-breathing effect */
    @keyframes hue-cycle {
      0%,100% { filter: hue-rotate(0deg)   saturate(1.0); }
      25%     { filter: hue-rotate(18deg)  saturate(1.15); }
      50%     { filter: hue-rotate(-12deg) saturate(0.9); }
      75%     { filter: hue-rotate(8deg)   saturate(1.1); }
    }

    /* will-change: only transform is compositable — border-radius morph repaints
       regardless, so hinting it just adds layer-management overhead. */
    .aurora-blob { will-change: transform; }

    /* Pause all aurora motion when the layer is scrolled out of view.
       JS toggles animation-play-state on .aurora-root; children inherit it. */
    .aurora-base,
    .aurora-blob { animation-play-state: inherit; }

    /* Blob 1 — large, upper-left: slow drift + organic shape morph */
    @keyframes blob-drift-1 {
      0%,100% {
        transform: translate(0px, 0px) scaleX(1.00) scaleY(1.00);
        border-radius: 60% 40% 30% 70% / 60% 30% 70% 40%;
      }
      20% {
        transform: translate(60px, -45px) scaleX(1.10) scaleY(0.90);
        border-radius: 30% 60% 70% 40% / 50% 60% 30% 60%;
      }
      40% {
        transform: translate(-35px, 60px) scaleX(0.90) scaleY(1.10);
        border-radius: 50% 50% 20% 80% / 25% 80% 20% 75%;
      }
      60% {
        transform: translate(45px, 35px) scaleX(1.06) scaleY(0.95);
        border-radius: 67% 33% 47% 53% / 37% 20% 80% 63%;
      }
      80% {
        transform: translate(-55px, -28px) scaleX(0.95) scaleY(1.05);
        border-radius: 40% 60% 55% 45% / 60% 30% 70% 40%;
      }
    }

    /* Blob 2 — medium, lower-right: counter-cycle + inverse morph */
    @keyframes blob-drift-2 {
      0%,100% {
        transform: translate(0px, 0px) scaleX(1.00) scaleY(1.00);
        border-radius: 40% 60% 60% 40% / 60% 30% 70% 40%;
      }
      25% {
        transform: translate(-65px, 40px) scaleX(0.90) scaleY(1.10);
        border-radius: 70% 30% 30% 70% / 40% 70% 30% 60%;
      }
      50% {
        transform: translate(40px, -60px) scaleX(1.12) scaleY(0.88);
        border-radius: 30% 70% 70% 30% / 50% 40% 60% 50%;
      }
      75% {
        transform: translate(-30px, 30px) scaleX(0.96) scaleY(1.04);
        border-radius: 55% 45% 40% 60% / 30% 60% 40% 70%;
      }
    }

    /* Blob 3 — mid-centre accent: rotational morph feel */
    @keyframes blob-drift-3 {
      0%,100% {
        transform: translate(calc(-50% + 0px),  calc(-50% + 0px));
        border-radius: 50% 50% 50% 50% / 50% 50% 50% 50%;
      }
      33% {
        transform: translate(calc(-50% + 45px), calc(-50% - 35px));
        border-radius: 30% 70% 60% 40% / 60% 40% 30% 70%;
      }
      66% {
        transform: translate(calc(-50% - 40px), calc(-50% + 45px));
        border-radius: 70% 30% 40% 60% / 40% 60% 70% 30%;
      }
    }

    /* Blob 4 — small sparkle, upper-right: quick organic flicker */
    @keyframes blob-drift-4 {
      0%,100% {
        transform: translate(0px, 0px);
        border-radius: 50% 50% 50% 50% / 50% 50% 50% 50%;
      }
      35% {
        transform: translate(28px, -22px);
        border-radius: 70% 30% 30% 70% / 30% 70% 70% 30%;
      }
      70% {
        transform: translate(-18px, 18px);
        border-radius: 30% 70% 70% 30% / 70% 30% 30% 70%;
      }
    }

    .blob-1 { animation: blob-drift-1 22s ease-in-out infinite; }
    .blob-2 { animation: blob-drift-2 30s ease-in-out infinite; }
    .blob-3 { animation: blob-drift-3 17s ease-in-out infinite; }
    .blob-4 { animation: blob-drift-4 20s ease-in-out infinite 2s; }
  }
</style>

<!-- Pause aurora motion when its layer is off-screen (perf — no visual change while visible).
     Hoisted + deduped by Astro, so it runs once per page and handles every instance. -->
<script>
  if (!window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    const roots = document.querySelectorAll<HTMLElement>('.aurora-root');
    if (roots.length) {
      const io = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            (entry.target as HTMLElement).style.animationPlayState =
              entry.isIntersecting ? 'running' : 'paused';
          });
        },
        { rootMargin: '120px' },
      );
      roots.forEach((root) => io.observe(root));
    }
  }
</script>

<!-- Parallax scroll handler (injected only when parallax={true}) -->
<script define:vars={{ parallax }}>
  if (parallax) {
    const root = document.getElementById('aurora-parallax-root');
    if (root && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
      let raf = null;
      const onScroll = () => {
        if (raf) return;
        raf = requestAnimationFrame(() => {
          const y = window.scrollY;
          // aurora drifts at 38% of scroll speed — feels like deep background
          root.style.transform = `translateY(${y * 0.38}px)`;
          raf = null;
        });
      };
      window.addEventListener('scroll', onScroll, { passive: true });
    }
  }
</script>
