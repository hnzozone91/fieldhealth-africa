---
const year = new Date().getFullYear();

const footerLinks = {
  'Tools': [
    { href: '/free-library', label: 'Free Library' },
    { href: '/pro-library',  label: 'Pro Tools'    },
    { href: '/picks',        label: 'Picks'         },
  ],
  'Organisation': [
    { href: '/about',   label: 'About'   },
    { href: '/blog',    label: 'Blog'    },
    { href: '/contact', label: 'Contact' },
    { href: 'https://drhenrynzozone.substack.com', label: 'Newsletter', external: true },
  ],
  'Legal': [
    { href: '/privacy',              label: 'Privacy Policy'       },
    { href: '/terms',                label: 'Terms of Use'         },
    { href: '/affiliate-disclosure', label: 'Affiliate Disclosure' },
    { href: '/cookies',              label: 'Cookie Policy'        },
  ],
};
---

<footer class="relative border-t mt-20" style="border-color: rgba(6,182,212,0.10);">
  <!-- Top glow line -->
  <div class="absolute inset-x-0 top-0 h-px" style="background: linear-gradient(90deg, transparent 0%, rgba(6,182,212,0.25) 30%, rgba(20,184,166,0.35) 50%, rgba(6,182,212,0.25) 70%, transparent 100%);"></div>

  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-14">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-4">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 mb-4 focus-visible:outline focus-visible:outline-2 focus-visible:outline-teal-400 rounded-lg" aria-label="FieldHealth Africa home">
          <img src="/images/logo.png" alt="" width="28" height="28" class="h-7 w-auto" onerror="this.style.display='none'" aria-hidden="true" />
          <span class="font-display font-bold text-white text-base">
            <span class="text-teal-400">Field</span>Health Africa
          </span>
        </a>
        <p class="text-white/50 text-sm leading-relaxed max-w-[220px]">
          From data to decisions, in the field.
        </p>
        <p class="font-mono text-white/28 text-[10px] mt-4 leading-relaxed tracking-wide">
          Built by a practising DMO<br/>in Mamfe, Cameroon.
        </p>
      </div>

      <!-- Link columns -->
      {Object.entries(footerLinks).map(([heading, links]) => (
        <div>
          <h3 class="font-mono text-white/35 text-[10px] uppercase tracking-widest mb-4">// {heading.toLowerCase()}</h3>
          <ul class="space-y-2.5" role="list">
            {links.map(({ href, label, external }) => (
              <li>
                <a
                  href={href}
                  {...(external ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
                  class="text-white/55 hover:text-cyan-300 text-sm transition-colors duration-200 focus-visible:outline focus-visible:outline-2 focus-visible:outline-teal-400 rounded"
                >
                  {label}
                </a>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>

    <!-- Bottom bar -->
    <div class="mt-12 pt-6 flex flex-col sm:flex-row items-center justify-between gap-4" style="border-top: 1px solid rgba(255,255,255,0.05);">
      <p class="font-mono text-white/28 text-[10px] tracking-wide">© {year} FieldHealth Africa. All rights reserved.</p>
      <p class="font-mono text-white/28 text-[10px] tracking-wide">
        Some links are affiliate links.{' '}
        <a href="/affiliate-disclosure" class="text-cyan-400/60 underline underline-offset-2 hover:text-cyan-300 transition-colors">
          See disclosure.
        </a>
      </p>
    </div>
  </div>
</footer>
